void systemHeartbeat() {
  static bool lastRunningState = false;
  unsigned long currentTime = millis(); // 잃어버린 변수 선언 추가!
  static unsigned long lastBlinkTime = 0;
  static bool ledState = false;

  // 1. Wi-Fi 끊김 경고 (최우선 실행: 노란색 깜빡임)
  if (WiFi.status() != WL_CONNECTED) {
    if (currentTime - lastBlinkTime >= 200) {
      lastBlinkTime = currentTime;
      ledState = !ledState;
      if (ledState) setLedColor(255, 150, 0); // 노란색
      else setLedColor(0, 0, 0); // 끄기
    }
    return; // Wi-Fi 끊겼을 때는 아래 코드는 무시
  }

  bool shouldBeOn = isRunning || (currentMode == MODE_DEMO);

  if(shouldBeOn) {
    if (!lastRunningState) {
      setLedColor(ledR, ledG, ledB);
      lastRunningState = true;
    }
  } else {
    if (lastRunningState) {
      setLedColor(0,0,0);
      lastRunningState = false;
    }
  }

  // 2. 분사 모드 가동 중일 때 (Wi-Fi 정상일 때만 작동)
  if (isRunning) {
    if (!lastRunningState) { 
      setLedColor(ledR, ledG, ledB); // 설정한 색상으로 켜기!
      lastRunningState = true;
    }
  } else {
    // 분사 모드가 완전히 끝나면 끄기
    if (lastRunningState) {
      setLedColor(0, 0, 0); // 끄기
      lastRunningState = false;
    }
  }
}

// --- 센서 데이터 처리 ---
void monitorWeight() {
  unsigned long currentTime = millis();
  
  // 측정 간격을 200ms -> 20ms로 대폭 단축 (초당 50번 확인)
  if (currentTime - lastWeightCheckTime <= 20) return;
  lastWeightCheckTime = currentTime;

  for (int i = 0; i < 4; i++) {
    if (scales[i].is_ready()) {
      // 샘플링 횟수를 1회로 줄여 딜레이를 완전히 제거
      float currentRawWeight = scales[i].get_units(1);

      // 하드웨어 오류로 인한 튀는 값(Spike)만 걸러냄
      if (currentRawWeight > 5000.0 || currentRawWeight < -500.0) continue;

      // [핵심] 필터링 없이 센서 값을 weights 배열에 즉시 박아넣음
      weights[i] = currentRawWeight; 
    }
  }

  // Nextion 디스플레이 바 업데이트 (현재 1번 로드셀 기준)
  // 만약 4번 로드셀(GPIO 32)을 메인으로 보려면 weights[3]으로 바꾸세요.
  int remainPercent = (int)((weights[0] / 150.0f) * 100.0f);
  updateProgressBar(constrain(remainPercent, 0, 100));
}

