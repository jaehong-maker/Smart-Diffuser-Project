// --- 유틸리티 함수: I2S 오디오 샘플에서 데시벨(dB) 계산 ---
static int calculateDecibels(int32_t* samples, int numSamples) {
  if (numSamples <= 0) return 0;
  
  double sumSquares = 0.0;
  for (int i = 0; i < numSamples; i++) {
    int16_t wave = (samples[i] >> 14);
    sumSquares += (double)wave * wave;
  }
  
  double rms = sqrt(sumSquares / numSamples);
  if (rms < 1.0) rms = 1.0; // log10(0) 예외 방지
  
  return (int)(20.0 * log10(rms));
}

void forceAllOff() {
  digitalWrite(PIN_SUNNY, HIGH);
  digitalWrite(PIN_CLOUDY, HIGH);
  digitalWrite(PIN_RAIN, HIGH);
  digitalWrite(PIN_SNOW, HIGH);
}

void stopSystem() {
  blendSelection = "";
  blendSprayActive = false;
  nexSend("b_blend.txt=\"동시분사ON\"");
  blendModeEnabled = false;
  forceAllOff();
  isRunning = false; 
  for (int i = 0; i < 4; i++) {
    activeNozzles[i] = false;
  }
  isSpraying = false;
  myDFPlayer.stop();
  updateDisplay(0, "Ready");
}

void playSound(int trackNum) { 
  myDFPlayer.play(trackNum); 
}

void bootAnimation() {
  for (int i = 0; i < 3; i++) {
    digitalWrite(PIN_LED, HIGH); delay(100);
    digitalWrite(PIN_LED, LOW);  delay(100);
  }
}

void systemHeartbeat() {
  unsigned long currentTime = millis();
  static unsigned long lastBlinkTime = 0;
  static bool ledState = false;

  // 1순위: 분사 중일 때는 LED 쨍하게 켜두기
  if (isSpraying) {
    analogWrite(PIN_LED, 255);
    return;
  }

  // 2순위: WiFi 연결 끊겼을 때 (에러 경고용으로 빠르게 깜빡임)
  if (WiFi.status() != WL_CONNECTED) {
    if (currentTime - lastBlinkTime >= 200) {
      lastBlinkTime = currentTime;
      ledState = !ledState;
      analogWrite(PIN_LED, ledState ? 200 : 0);
    }
    return;
  }

  // 3순위: 대기 상태 (✨ 애플 감성 찐 숨쉬기 모드 ✨)
  // 사람의 실제 호흡 주기와 유사한 비선형(지수-사인) 곡선 수학 공식 적용
  float val = (exp(sin(currentTime / 1500.0 * PI)) - 0.36787944) * 108.0;
  int brightness = constrain((int)val, 0, 255);
  
  // 혹시 밤에 너무 눈부시면 위에 108.0 숫자를 한 70~80으로 줄이면 됨!
  analogWrite(PIN_LED, brightness);
}

// 중간값을 찾기 위한 간단한 정렬 함수 (샘플 개수가 적어서 버블 정렬로 충분해)
void sortArray(float* arr, int size) {
  for (int i = 0; i < size - 1; i++) {
    for (int j = 0; j < size - i - 1; j++) {
      if (arr[j] > arr[j + 1]) {
        float temp = arr[j];
        arr[j] = arr[j + 1];
        arr[j + 1] = temp;
      }
    }
  }
}

void monitorWeight() {
  unsigned long currentTime = millis();
  
  if (currentTime - lastWeightCheckTime <= 200) return;
  lastWeightCheckTime = currentTime;
  
  const float alpha = 0.15;
  const int sampleCount = 3;

  for (int i = 0; i < 4; i++) {
    if (scales[i].is_ready()) {
      float samples[sampleCount];
      
      for (int s = 0; s < sampleCount; s++) {
        samples[s] = scales[i].get_units(1);
        delay(2);
      }

      sortArray(samples, sampleCount);
      float medianVal = samples[sampleCount / 2];

      if (medianVal > 1000.0 || medianVal < -50.0) continue;

      if (weights[i] == 0.0) {
        weights[i] = medianVal;
      } else {
        weights[i] = (alpha * medianVal) + ((1.0 - alpha) * weights[i]);
      }
    }
  }

  // 카트리지 잔량 표시 (150g = 100%)
  float cartridgeWeight = weights[0];   // 카트리지 연결 채널에 맞게 변경
  if (cartridgeWeight < 0) cartridgeWeight = 0;

  int remainPercent = (int)((cartridgeWeight / 150.0f) * 100.0f);
  remainPercent = constrain(remainPercent, 0, 100);

  updateProgressBar(remainPercent);

  // 텍스트 표시용 컴포넌트가 있으면 사용
  // nexSend("t_percent.txt=\"" + String(remainPercent) + "%\"");
}

