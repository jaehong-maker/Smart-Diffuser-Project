// --- 유틸리티 함수: I2S 오디오 샘플에서 데시벨(dB) 계산 ---
static int calculateDecibels(int32_t* samples, int numSamples) {
  if (numSamples <= 0) return 0;
  
  double sumSquares = 0.0;
  for (int i = 0; i < numSamples; i++) {
    int16_t wave = (samples[i] >> 14);
    sumSquares += (double)wave * wave;
  }
  
  double rms = sqrt(sumSquares / numSamples);
  if (rms < 1.0) rms = 1.0; // log10(0) 예외 방지
  
  return (int)(20.0 * log10(rms));
}

void forceAllOff() {
  digitalWrite(PIN_SUNNY, HIGH);
  digitalWrite(PIN_CLOUDY, HIGH);
  digitalWrite(PIN_RAIN, HIGH);
  digitalWrite(PIN_SNOW, HIGH);
}

void stopSystem() {
  forceAllOff();
  isRunning = false; 
  activePin = -1; 
  isSpraying = false;
  myDFPlayer.stop();
  updateDisplay(0, "Ready");
}

void playSound(int trackNum) { 
  myDFPlayer.play(trackNum); 
}

void bootAnimation() {
  for (int i = 0; i < 3; i++) {
    digitalWrite(PIN_LED, HIGH); delay(100);
    digitalWrite(PIN_LED, LOW);  delay(100);
  }
}

void systemHeartbeat() {
  if (isRunning) return; // 실행 중일 때는 심장박동 LED 점멸 생략
  
  unsigned long currentTime = millis();
  if (currentTime - prevLedMillis >= 30) {
    prevLedMillis = currentTime;
    ledBrightness += ledFadeAmount;
    
    if (ledBrightness <= 0 || ledBrightness >= 255) {
      ledFadeAmount = -ledFadeAmount;
    }
    analogWrite(PIN_LED, ledBrightness);
  }
}

// 중간값을 찾기 위한 간단한 정렬 함수 (샘플 개수가 적어서 버블 정렬로 충분해)
void sortArray(float* arr, int size) {
  for (int i = 0; i < size - 1; i++) {
    for (int j = 0; j < size - i - 1; j++) {
      if (arr[j] > arr[j + 1]) {
        float temp = arr[j];
        arr[j] = arr[j + 1];
        arr[j + 1] = temp;
      }
    }
  }
}

void monitorWeight() {
  unsigned long currentTime = millis();
  
  // 센서 읽기 주기 (HX711 속도 고려해서 200ms 유지)
  if (currentTime - lastWeightCheckTime <= 200) return;
  lastWeightCheckTime = currentTime;
  
  const float alpha = 0.15; // EMA 가중치
  const int sampleCount = 3; // Median 필터용 샘플 개수 (3~5개 추천)

  for (int i = 0; i < 4; i++) {
    if (scales[i].is_ready()) {
      float samples[sampleCount];
      
      // 1단계: 연속으로 여러 번 읽어서 샘플 수집
      for (int s = 0; s < sampleCount; s++) {
        samples[s] = scales[i].get_units(1);
        delay(2); // 아주 짧은 간격을 둬서 읽기
      }

      // 2단계: 정렬 후 중간값(Median) 선택 (노이즈 제거)
      sortArray(samples, sampleCount);
      float medianVal = samples[sampleCount / 2];

      // 3단계: 유효 범위 검사 (-50g ~ 1000g)
      if (medianVal > 1000.0 || medianVal < -50.0) continue; 

      // 4단계: EMA 필터 적용 (부드러운 값 갱신)
      if (weights[i] == 0.0) {
        weights[i] = medianVal; // 초기값 설정
      } else {
        weights[i] = (alpha * medianVal) + ((1.0 - alpha) * weights[i]);
      }
    }
  }
}

void printCalibrationInfo() {
  Serial.printf("보정값: %.1f | W1:%.1f W2:%.1f W3:%.1f W4:%.1f (g)\r\n", 
              calibration_factor, 
              scales[0].get_units(2), scales[1].get_units(2), 
              scales[2].get_units(2), scales[3].get_units(2));
}

void initMicrophone() {
  const i2s_config_t i2s_config = {
    .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX),
    .sample_rate = SAMPLE_RATE,
    .bits_per_sample = I2S_BITS_PER_SAMPLE_16BIT,
    .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = i2s_comm_format_t(I2S_COMM_FORMAT_I2S | I2S_COMM_FORMAT_I2S_MSB),
    .intr_alloc_flags = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count = 8,
    .dma_buf_len = 64,
    .use_apll = false,
    .tx_desc_auto_clear = false,
    .fixed_mclk = 0
  };
  const i2s_pin_config_t pin_config = {
    .bck_io_num = I2S_SCK, .ws_io_num = I2S_WS, .data_out_num = I2S_PIN_NO_CHANGE, .data_in_num = I2S_SD
  };
  i2s_driver_install(I2S_PORT, &i2s_config, 0, NULL);
  i2s_set_pin(I2S_PORT, &pin_config);
}

int32_t readMicrophone() {
  int16_t sample = 0; 
  size_t bytes_read = 0;
  i2s_read(I2S_PORT, &sample, sizeof(sample), &bytes_read, 0);
  return (bytes_read > 0) ? abs(sample) : 0;
}

void runSoundVisualizer() {
  int32_t sample = 0; 
  size_t bytes_read = 0;
  i2s_read(I2S_PORT, &sample, sizeof(sample), &bytes_read, 0);
  
  if (bytes_read == 0) return;
  
  unsigned long currentTime = millis();
  static unsigned long lastVisUpdate = 0;
  
  if (currentTime - lastVisUpdate > 100) { 
    lastVisUpdate = currentTime;
    
    int16_t wave = (sample >> 14); 
    int vol = abs(wave); 
    if (vol < 100) vol = 0;
    
    int bars = constrain(map(vol, 0, 5000, 0, 30), 0, 30); 
    
    Serial.print("\r\033[K"); Serial.print(C_CYAN "🎤 Sound: " C_RESET);
    Serial.print(C_GREEN); 
    for(int i = 0; i < bars; i++) Serial.print("█");
    for(int i = bars; i < 30; i++) Serial.print(" ");
    Serial.print(C_RESET); Serial.printf(" [%d]", vol);
    
    updateProgressBar(map(vol, 0, 5000, 0, 100));
  }
}

void runSoundReaction() {
  int32_t samples[64]; 
  size_t bytes_read = 0;
  i2s_read(I2S_PORT, &samples, sizeof(samples), &bytes_read, 0);
  
  if (bytes_read == 0) return;

  int db = calculateDecibels(samples, bytes_read / sizeof(int32_t));
  unsigned long currentTime = millis();
  static unsigned long lastPrint = 0;
  
  if (currentTime - lastPrint > 500) {
    lastPrint = currentTime;
    Serial.printf("\r\033[K📢 Noise: %d dB (Target: >%d)\r", db, soundThreshold);
    updateDisplay(0, String(db) + " dB / " + String(soundThreshold));
  }
  
  if (db >= soundThreshold && (currentTime - lastReactionTime > 5000)) { 
    lastReactionTime = currentTime;
    Serial.printf("\n\n🎉 [Sound Trigger] %d dB! 자동 분사!\n", db);
    updateDisplay(0, "LOUD NOISE!");
    
    int cmd = random(1, 5); 
    forceAllOff();
    
    int musicTrack = 1; 
    if (cmd == 1) { activePin = PIN_SUNNY; musicTrack = random(1, 6); } 
    else if (cmd == 2) { activePin = PIN_CLOUDY; musicTrack = random(6, 11); } 
    else if (cmd == 3) { activePin = PIN_RAIN; musicTrack = random(11, 16); } 
    else if (cmd == 4) { activePin = PIN_SNOW; musicTrack = random(16, 21); }
    
    isRunning = true; 
    isSpraying = true; 
    sprayDuration = 3000;
    prevMotorMillis = currentTime; 
    startTimeMillis = currentTime;
    
    digitalWrite(activePin, LOW); 
    playSound(musicTrack); 
    updateDisplay(cmd, "Sound Active");
  }
}

void checkBackgroundNoise() {
  int32_t samples[32]; 
  size_t bytes_read = 0;
  
  i2s_read(I2S_PORT, &samples, sizeof(samples), &bytes_read, 0);
  if (bytes_read == 0) return;
  
  int current_db = calculateDecibels(samples, bytes_read / sizeof(int32_t));
  
  static float smoothed_db = 0;
  smoothed_db = (0.3 * current_db) + (0.7 * smoothed_db);
  int final_db = (int)smoothed_db;
  
  unsigned long currentTime = millis();
  static int trigger_count = 0;
  
  if (final_db >= soundThreshold) {
    trigger_count++;
  } else {
    trigger_count = 0;
  }
  
  // 이미 음성 인식 모드(6)가 아닐 때만 반응하도록 방어
  if (currentMode != 6 && trigger_count >= 3 && (currentTime - lastReactionTime > 5000)) { 
    lastReactionTime = currentTime;
    trigger_count = 0; 
    
    Serial.print("\r\033[K"); 
    Serial.printf("\033[36m[Core 0] %d dB 감지! Core 1로 큐(Queue) 전송...\033[0m\r\n", final_db);
    
    // ★ [업그레이드] 직접 통신하지 않고 큐(Queue)에 이벤트 코드(1) 삽입
    int eventCode = 1; // 1 = 음성 인식 시작 트리거
    xQueueSend(audioEventQueue, &eventCode, 0); 
  }
}

// ★ Core 0에서 무한 반복되며 실행될 태스크
void sensorTaskLoop(void *parameter) {
  for (;;) {
    // 음성 대기 모드나 기본 상태일 때 백그라운드 소음 감지 전담
    if (currentMode != 7 && currentMode != 8 && currentMode != 6) {
        checkBackgroundNoise();
    }
    
    // Core 0의 워치독 타이머(WDT) 에러를 방지하기 위해 2ms 휴식
    vTaskDelay(2 / portTICK_PERIOD_MS); 
  }
}
