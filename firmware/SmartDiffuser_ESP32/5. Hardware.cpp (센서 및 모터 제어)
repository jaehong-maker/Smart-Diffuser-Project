// ★ 만능 LED 색상 제어 함수 (전체 LED 적용으로 업그레이드)
void setLedColor(uint8_t r, uint8_t g, uint8_t b) {
  // 전체 밝기 제한 적용 (0~255)
  strip.setBrightness(ledBrightness); 
  
  for(int i = 0; i < NUM_LEDS; i++) {
    strip.setPixelColor(i, strip.Color(r, g, b));
  }
  strip.show();
}
