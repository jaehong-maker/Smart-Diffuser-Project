void setLedColor(uint8_t r, uint8_t g, uint8_t b) {
  strip.setBrightness(ledBrightness); 
  
  for(int i = 0; i < NUM_LEDS; i++) {
    // 인덱스 0, 1, 2, 3 (처음 4개)는 강제로 끕니다 (R:0, G:0, B:0)
    if (i < 4) {
      strip.setPixelColor(i, strip.Color(0, 0, 0));
    } 
    // 나머지 8개(인덱스 4~11)는 정상적으로 색상을 켭니다
    else {
      strip.setPixelColor(i, strip.Color(r, g, b));
    }
  }
  
  strip.show();
}

void bootAnimation() {
  for (int i = 0; i < 3; i++) {
    setLedColor(ledR, ledG, ledB); 
    delay(100);
    setLedColor(0, 0, 0); 
    delay(100);
  }
}

void systemHeartbeat() {
  if (!ledEnabled) {
    setLedColor(0, 0, 0);
    return;
  }

  unsigned long currentTime = millis();
  static unsigned long lastUpdate = 0;
  static int effectStep = 0;

  // 1. 상태 체크: 센서 고장 및 잔량 부족 확인
  bool isAnySensorBroken = !isAudioOk; 
  bool isFluidLow = false;

  for (int i = 0; i < 4; i++) {
    if (!isSensorOk[i]) isAnySensorBroken = true;
    if (weights[i] > 0.5f && weights[i] < (Config::EMPTY_WEIGHT + 2.0f)) isFluidLow = true;
  }

  // 2. 현재 시스템 상태에 따라 LED 상태 결정 (우선순위 순)
  enum LedState { LED_SENSOR_ERR, LED_LOW_FLUID, LED_WIFI_ERR, LED_SPRAY, LED_AMBIENT, LED_IDLE };
  LedState currentLedState;

  if (isAnySensorBroken) currentLedState = LED_SENSOR_ERR;
  else if (isFluidLow) currentLedState = LED_LOW_FLUID;
  else if (WiFi.status() != WL_CONNECTED) currentLedState = LED_WIFI_ERR;
  else if (isSpraying || isRunning) currentLedState = LED_SPRAY;
  else if (currentMode == MODE_AMBIENT) currentLedState = LED_AMBIENT;
  else currentLedState = LED_IDLE;

  // 3. 상태별 애니메이션 (Non-blocking 방식)
  switch (currentLedState) {
    case LED_SENSOR_ERR: // 🔴 센서 고장 (빠른 빨간색 점멸)
      if (currentTime - lastUpdate >= 300) { 
        lastUpdate = currentTime; effectStep = !effectStep;
        setLedColor(effectStep ? 255 : 0, 0, 0); 
      }
      break;

    case LED_LOW_FLUID: // 🟡 용액 부족 (경고만 살짝 덧씌움)
      {
        // [수정] 사용자가 설정한 색상을 기본으로 하되, 2초 주기로 노란색이 살짝 나타났다 사라지게 변경
        int factor = (sin(currentTime / 500.0) * 30) + 225;
        float warningFactor = (sin(currentTime / 2000.0) * 0.5) + 0.5; // 0~1 범위
        
        // 사용자 색상과 경고 노란색(255, 200, 0)을 부드럽게 믹스
        uint8_t r = (ledR * (1.0 - (warningFactor * 0.3))) + (255 * warningFactor * 0.3);
        uint8_t g = (ledG * (1.0 - (warningFactor * 0.3))) + (200 * warningFactor * 0.3);
        uint8_t b = (ledB * (1.0 - (warningFactor * 0.3)));
        
        setLedColor((r * factor) / 255, (g * factor) / 255, (b * factor) / 255);
      }
      break;

    case LED_WIFI_ERR: // 🔵 와이파이 에러 (파란색 깜빡임)
      if (currentTime - lastUpdate >= 600) {
        lastUpdate = currentTime; effectStep = !effectStep;
        setLedColor(0, 0, effectStep ? 255 : 0); 
      }
      break;

    case LED_SPRAY: // ✨ 분사 중 (빠른 호흡 효과)
      {
        // [수정] 사용자가 설정한 색상을 사용하며, 165~255 범위에서 빠르게 박동
        int factor = (sin(currentTime / 200.0) * 45) + 210; 
        setLedColor((ledR * factor) / 255, (ledG * factor) / 255, (ledB * factor) / 255);
      }
      break;

    case LED_AMBIENT: // 🔮 앰비언트 모드 (부드러운 호흡)
      {
        // [수정] 기존 하드코딩된 보라색 대신, 사용자가 설정한 색상을 175~255 범위에서 부드럽게 박동
        int factor = (sin(currentTime / 500.0) * 40) + 215; 
        setLedColor((ledR * factor) / 255, (ledG * factor) / 255, (ledB * factor) / 255);
      }
      break;

    case LED_IDLE: // 💤 대기 모드 (은은한 숨쉬기)
    default:
      {
        // [수정] 대기 모드에서는 색상 변경이 가장 뚜렷하게 보이도록 박동 범위를 좁히고 밝게 유지 (245~255)
        int factor = (sin(currentTime / 2000.0) * 10) + 245; 
        setLedColor((ledR * factor) / 255, (ledG * factor) / 255, (ledB * factor) / 255);
      }
      break;
  }
}

