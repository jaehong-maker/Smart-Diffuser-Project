void initMicrophone() {
  const i2s_config_t i2s_config = {
    .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX),
    .sample_rate = SAMPLE_RATE,
    .bits_per_sample = I2S_BITS_PER_SAMPLE_16BIT,
    .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = i2s_comm_format_t(I2S_COMM_FORMAT_I2S | I2S_COMM_FORMAT_I2S_MSB),
    .intr_alloc_flags = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count = 8,
    .dma_buf_len = 64,
    .use_apll = false,
    .tx_desc_auto_clear = false,
    .fixed_mclk = 0
  };
  const i2s_pin_config_t pin_config = {
    .bck_io_num = I2S_SCK, .ws_io_num = I2S_WS, .data_out_num = I2S_PIN_NO_CHANGE, .data_in_num = I2S_SD
  };
  i2s_driver_install(I2S_PORT, &i2s_config, 0, NULL);
  i2s_set_pin(I2S_PORT, &pin_config);
}

void runSoundVisualizer() {
  int32_t sample = 0; 
  size_t bytes_read = 0;
  i2s_read(I2S_PORT, &sample, sizeof(sample), &bytes_read, 0);
  if (bytes_read == 0) return;
  
  unsigned long currentTime = millis();
  static unsigned long lastVisUpdate = 0;
  if (currentTime - lastVisUpdate > 100) { 
    lastVisUpdate = currentTime;
    int vol = abs(sample >> 14); 
    if (vol < 100) vol = 0;
    int bars = constrain(map(vol, 0, 5000, 0, 30), 0, 30); 
    Serial.print("\r\033[K"); Serial.print(C_CYAN "🎤 Sound: " C_RESET C_GREEN);
    for(int i = 0; i < bars; i++) Serial.print("█");
    Serial.printf(C_RESET " [%d]", vol);
    updateProgressBar(map(vol, 0, 5000, 0, 100));
  }
}

void runSoundReaction() {
  int32_t samples[64]; 
  size_t bytes_read = 0;
  i2s_read(I2S_PORT, &samples, sizeof(samples), &bytes_read, 0);
  if (bytes_read == 0) return;

  int db = calculateDecibels(samples, bytes_read / sizeof(int32_t));
  unsigned long currentTime = millis();
  
  if (db >= soundThreshold && (currentTime - lastReactionTime > 5000)) { 
    lastReactionTime = currentTime;
    int cmd = random(1, 5); 
    triggerSpray(cmd, 3, 0, "LOUD NOISE TRIGGER", false);
  }
}

void checkBackgroundNoise() {
  int32_t samples[32]; 
  size_t bytes_read = 0;
  i2s_read(I2S_PORT, &samples, sizeof(samples), &bytes_read, 0);
  if (bytes_read == 0) return;
  
  int current_db = calculateDecibels(samples, bytes_read / sizeof(int32_t));
  static float smoothed_db = 0;
  smoothed_db = (0.3 * current_db) + (0.7 * smoothed_db);
  
  unsigned long currentTime = millis();
  static int trigger_count = 0;
  if ((int)smoothed_db >= soundThreshold) trigger_count++;
  else trigger_count = 0;
  
  if (currentMode != 6 && trigger_count >= 3 && (currentTime - lastReactionTime > 5000)) { 
    lastReactionTime = currentTime;
    trigger_count = 0; 
    int eventCode = 1; 
    xQueueSend(audioEventQueue, &eventCode, 0); 
  }
}

void sensorTaskLoop(void *parameter) {
  for (;;) {
    if (currentMode != 7 && currentMode != 8 && currentMode != 6) {
        checkBackgroundNoise();
    }
    vTaskDelay(2 / portTICK_PERIOD_MS); 
  }
}

// --- RFID 기능 ---

void initRFID() {
  SPI.begin(RFID_SCK, RFID_MISO, RFID_MOSI, RFID_CS);
  mfrc522.PCD_Init();
  Serial.println("\r\n[System] RC522 RFID 모듈 초기화 완료.");
}

void checkRFIDTag() {
  if (!mfrc522.PICC_IsNewCardPresent() || !mfrc522.PICC_ReadCardSerial()) return;

  String uidString = "";
  for (byte i = 0; i < mfrc522.uid.size; i++) {
    uidString += String(mfrc522.uid.uidByte[i] < 0x10 ? "0" : "");
    uidString += String(mfrc522.uid.uidByte[i], HEX);
  }
  uidString.toUpperCase();

  Serial.printf("\r\n[RFID] UID 감지: %s\r\n", uidString.c_str());
  updateDisplay(0, "RFID: " + uidString);

  String payload = "{\"mode\": \"rfid_auth\", \"uid\": \"" + uidString + "\", \"deviceId\": \"SmartDiffuser_01\"}";
  sendServerRequest(payload); 

  mfrc522.PICC_HaltA();
  mfrc522.PCD_StopCrypto1();
}

void runAmbientMode() {
  // ★ 수정 1: isSpraying 제한 해제! 이제 향을 뿌리는 중에도 n키나 수음 로직이 정상 작동합니다.
  if (isWaitingForTestDb) return; 

  unsigned long currentTime = millis();

  // 1. 트리거 조건: 노래 시작 후 5초가 지났고 BUSY가 HIGH(노래 끝남)일 때 
  bool isSongFinished = (digitalRead(PIN_BUSY) == HIGH && (currentTime - lastAmbientTime > 5000));

  // 2. 실행 조건: 최초 실행 OR 노래 끝남 OR n키 눌림
  if (isFirstAmbientRun || isSongFinished || forceAmbientSkip) {
    
    forceAmbientSkip = false; // 플래그 해제
    lastAmbientTime = currentTime; // 중복 진입 방지 쿨타임 시작

    myDFPlayer.stop();
    delay(100); // 잔향 대기

    Serial.printf(C_CYAN "\r\n[Ambient Scan %d/%s] 주변 소음 측정 중...\r\n" C_RESET, 
                  ambientCycleCount + 1, isFirstAmbientRun ? "1(최초)" : "5");

    // 3초간 30회 수음
    const int sampleCount = 30;
    int dbSamples[sampleCount];
    
    for (int i = 0; i < sampleCount; i++) {
      int32_t samples[64];
      size_t bytes_read = 0;
      
      // 0.1초 타임아웃 적용하여 뻗음 방지
      i2s_read(I2S_PORT, &samples, sizeof(samples), &bytes_read, 100 / portTICK_PERIOD_MS);
      dbSamples[i] = (bytes_read > 0) ? calculateDecibels(samples, bytes_read / sizeof(int32_t)) : 0;
      
      // ★★★ 수정 2: 수음(3초) 대기 중에도 모터 타이머가 멈추지 않게 분사 로직을 강제 호출! ★★★
      if (isRunning) {
        runSprayLogic(); 
      }

      delay(100);
    }

    // 튀는 값 버블 정렬 필터링
    for (int i = 0; i < sampleCount - 1; i++) {
      for (int j = 0; j < sampleCount - i - 1; j++) {
        if (dbSamples[j] > dbSamples[j + 1]) {
          int temp = dbSamples[j];
          dbSamples[j] = dbSamples[j + 1];
          dbSamples[j + 1] = temp;
        }
      }
    }

    int stableDB = dbSamples[sampleCount / 2];
    ambientCycleStorage[ambientCycleCount] = stableDB;
    ambientCycleCount++;

    Serial.printf(C_GREEN "✅ 측정 완료: %d dB\r\n" C_RESET, stableDB);

    // 5주기 누적 및 서버 전송
    if (isFirstAmbientRun || ambientCycleCount >= 5) {
      int sumDB = 0;
      int count = isFirstAmbientRun ? 1 : 5;
      for (int i = 0; i < count; i++) sumDB += ambientCycleStorage[i];
      int avgDB = sumDB / count;
      
      Serial.printf(C_YELLOW "🌐 서버 전송: 누적 평균 %d dB\r\n" C_RESET, avgDB);
      sendServerRequest("{\"mode\": \"ambient\", \"db_level\": " + String(avgDB) + "}");
      
      ambientCycleCount = 0;
      isFirstAmbientRun = false; 
    } else {
      Serial.println("데이터 누적 중... (서버 전송 생략)");
    }

    // 다음 곡 재생
    currentAmbientTrack++;
    if (currentAmbientTrack > 20) currentAmbientTrack = 1;
    playSound(currentAmbientTrack);
    Serial.printf(C_BLUE "🎵 노래 시작: %d번 트랙\r\n" C_RESET, currentAmbientTrack);
    
    lastAmbientTime = millis(); // ★ 노래 시작 시간 기록 (이후 5초간 수음 절대 금지)
  }
}

