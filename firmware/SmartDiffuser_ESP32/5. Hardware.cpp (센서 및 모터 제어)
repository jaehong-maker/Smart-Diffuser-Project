enum LedState { LED_WIFI_ERR, LED_IDLE, LED_SPRAY, LED_AMBIENT };
LedState currentLedState = LED_IDLE;

void systemHeartbeat() {
  unsigned long currentTime = millis();
  static unsigned long lastUpdate = 0;
  static int effectStep = 0;

  // 1. 현재 시스템 상태에 따라 LED 상태 결정 (우선순위 순)
  if (WiFi.status() != WL_CONNECTED) currentLedState = LED_WIFI_ERR;
  else if (isSpraying || isRunning) currentLedState = LED_SPRAY;
  else if (currentMode == MODE_AMBIENT) currentLedState = LED_AMBIENT;
  else currentLedState = LED_IDLE;

  // 2. 상태별 애니메이션 (Non-blocking)
  switch (currentLedState) {
    case LED_WIFI_ERR:
      if (currentTime - lastUpdate >= 200) {
        lastUpdate = currentTime;
        effectStep = !effectStep;
        if (effectStep) setLedColor(255, 150, 0); // 주황색 점멸 (경고)
        else setLedColor(0, 0, 0);
      }
      break;

    case LED_SPRAY:
      if (currentTime - lastUpdate >= 50) { // 빙글빙글 도는 속도
        lastUpdate = currentTime;
        strip.clear(); // 전체 소등 후
        // 2칸짜리 빛이 뱅글뱅글 도는 스피너 효과
        strip.setPixelColor(effectStep % NUM_LEDS, strip.Color(ledR, ledG, ledB));
        strip.setPixelColor((effectStep + 1) % NUM_LEDS, strip.Color(ledR, ledG, ledB));
        strip.setBrightness(ledBrightness);
        strip.show();
        effectStep++;
      }
      break;

    case LED_AMBIENT:
      if (currentTime - lastUpdate >= 300) {
        lastUpdate = currentTime;
        effectStep = !effectStep;
        // 수음 중일 때는 보라색 점멸
        if (effectStep) setLedColor(128, 0, 255); 
        else setLedColor(0, 0, 0);
      }
      break;

    case LED_IDLE:
    default:
      // 기존 숨쉬기(Breathing) 효과 유지
      float val = (exp(sin(currentTime / 1500.0 * PI)) - 0.36787944) * 108.0;
      int bright = constrain((int)val, 0, 255);
      setLedColor((ledR * bright) / 255, (ledG * bright) / 255, (ledB * bright) / 255);
      break;
  }
}

// --- 센서 데이터 처리 ---
void monitorWeight() {
  unsigned long currentTime = millis();
  
  // 측정 간격을 200ms -> 20ms로 대폭 단축 (초당 50번 확인)
  if (currentTime - lastWeightCheckTime <= 20) return;
  lastWeightCheckTime = currentTime;

  for (int i = 0; i < 4; i++) {
    if (scales[i].is_ready()) {
      // 샘플링 횟수를 1회로 줄여 딜레이를 완전히 제거
      float currentRawWeight = scales[i].get_units(1);

      // 하드웨어 오류로 인한 튀는 값(Spike)만 걸러냄
      if (currentRawWeight > 5000.0 || currentRawWeight < -500.0) continue;

      // [핵심] 필터링 없이 센서 값을 weights 배열에 즉시 박아넣음
      weights[i] = currentRawWeight; 
    }
  }

  // Nextion 디스플레이 바 업데이트 (현재 1번 로드셀 기준)
  // 만약 4번 로드셀(GPIO 32)을 메인으로 보려면 weights[3]으로 바꾸세요.
  int remainPercent = (int)((weights[0] / 150.0f) * 100.0f);
  updateProgressBar(constrain(remainPercent, 0, 100));
}

