// --- 유틸리티 함수: I2S 오디오 샘플에서 데시벨(dB) 계산 ---
static int calculateDecibels(int32_t* samples, int numSamples) {
  if (numSamples <= 0) return 0;
  
  double sumSquares = 0.0;
  for (int i = 0; i < numSamples; i++) {
    int16_t wave = (samples[i] >> 14);
    sumSquares += (double)wave * wave;
  }
  
  double rms = sqrt(sumSquares / numSamples);
  if (rms < 1.0) rms = 1.0; 
  
  return (int)(20.0 * log10(rms));
}

// 데이터 필터링을 위한 정렬 함수
void sortArray(float* arr, int size) {
  for (int i = 0; i < size - 1; i++) {
    for (int j = 0; j < size - i - 1; j++) {
      if (arr[j] > arr[j + 1]) {
        float temp = arr[j];
        arr[j] = arr[j + 1];
        arr[j + 1] = temp;
      }
    }
  }
}

// --- 하드웨어 출력 제어 ---

void forceAllOff() {
  digitalWrite(PIN_SUNNY, HIGH);
  digitalWrite(PIN_CLOUDY, HIGH);
  digitalWrite(PIN_RAIN, HIGH);
  digitalWrite(PIN_SNOW, HIGH);
}

void stopSystem() {
  blendSelection = "";
  blendSprayActive = false;
  nexSend("b_blend.txt=\"blendON\"");
  blendModeEnabled = false;
  forceAllOff();
  isRunning = false;
  for (int i = 0; i < 4; i++) {
    activeNozzles[i] = false;
  }
  isSpraying = false;
  myDFPlayer.stop();
  updateDisplay(0, "Ready");
}

void resetManualState() {
  forceAllOff();
  myDFPlayer.stop();
  isRunning = false;
  isSpraying = false;
  sprayDuration = 0;
  prevMotorMillis = 0;
  startTimeMillis = 0;
  for (int i = 0; i < 4; i++) {
    activeNozzles[i] = false;
  }
  blendModeEnabled = false;
  blendSelection = "";
  blendSprayActive = false;
  nexSend("b_blend.txt=\"blendON\"");
}

void stopSprayOnly() {
  forceAllOff();
  isRunning = false;
  isSpraying = false;
  for (int i = 0; i < 4; i++) {
    activeNozzles[i] = false;
  }
  myDFPlayer.stop();
