void setSprayIntensity(int intensityVal) {
    currentIntensity = intensityVal;
    if (currentIntensity == 1) REST_TIME = 9000;      // 약
    else if (currentIntensity == 2) REST_TIME = 6000; // 중
    else REST_TIME = 3000;                            // 강
}

int getPinFromCommand(int cmd) {
  switch(cmd) {
    case 1: return PIN_SUNNY;
    case 2: return PIN_CLOUDY;
    case 3: return PIN_RAIN;
    case 4: return PIN_SNOW;
    default: return -1;
  }
}
