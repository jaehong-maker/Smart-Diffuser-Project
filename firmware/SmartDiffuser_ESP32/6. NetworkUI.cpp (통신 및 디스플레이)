void initOTA() {
  ArduinoOTA.setHostname("SmartDiffuser");

  // ★ 여기에 비밀번호를 설정해! (사진의 그 창에 입력할 번호)
  ArduinoOTA.setPassword("1234");
  
  ArduinoOTA.onStart([]() {
    String type = (ArduinoOTA.getCommand() == U_FLASH) ? "sketch" : "filesystem";
    Serial.println("\r\n[OTA] 무선 업데이트 시작: " + type);
    updateDisplay(0, "Updating..."); 
  });
  ArduinoOTA.onEnd([]() { Serial.println("\r\n[OTA] 무선 업데이트 완료!"); updateDisplay(0, "Update Done"); });
  ArduinoOTA.onProgress([](unsigned int progress, unsigned int total) {
    int percent = (progress / (total / 100));
    Serial.printf("\r[OTA] 진행률: %u%%\r", percent);
    updateProgressBar(percent);
  });
  ArduinoOTA.onError([](ota_error_t error) { Serial.printf("\r\n[OTA] 에러 발생[%u]: ", error); updateDisplay(0, "OTA Error"); });
  ArduinoOTA.begin();
  Serial.println(C_CYAN "[System] OTA 무선 업데이트 준비 완료" C_RESET);
}

void handleOTA() { ArduinoOTA.handle(); }
