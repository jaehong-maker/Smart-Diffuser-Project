void networkTaskLoop(void *pvParameters) {
  for (;;) {
    EventBits_t bits = xEventGroupWaitBits(networkEventGroup, BIT_SEND_POLL | BIT_SEND_VOICE | BIT_SEND_REQUEST, pdTRUE, pdFALSE, portMAX_DELAY);
    if (WiFi.status() != WL_CONNECTED) { vTaskDelay(100 / portTICK_PERIOD_MS); continue; }

    isCommunicate = true; initNetworkSession(); HTTPClient http; http.setTimeout(10000); 
    if (http.begin(sharedClient, serverName)) {
      http.addHeader("Content-Type", "application/json");
      int httpCode = http.POST(globalPayload);
      if (httpCode == HTTP_CODE_OK) {
        String response = http.getString();
        if (bits & BIT_SEND_VOICE) { executeVoiceCommand(response); } 
        else {
          JsonDocument doc;
          if (!deserializeJson(doc, response)) {
            int cmd = doc["spray"] | 0;
            if (cmd > 0) {
              int dur = doc["duration"] | 3; int music = doc["music"] | 0; String txt = doc["result_text"] | "명령 수신";
              triggerSpray(cmd, dur, music, txt, (currentMode == MODE_WEATHER));
            }
          }
        }
      }
      http.end();
    }
    isCommunicate = false; vTaskDelay(10 / portTICK_PERIOD_MS);
  }
}
