void initNetworkSession() {
  if (!isSessionInit) { sharedClient.setInsecure(); isSessionInit = true; }
}

// --- NetworkUI.cpp 파일의 triggerSpray 함수 수정 ---
void triggerSpray(int cmd, int dur, int music, String txt, bool isWeatherMode) {
  forceAllOff();
  
  // DRY 원칙 적용: SystemLogic 모듈의 파싱 및 노즐 활성화 유틸리티 재사용
  String cmdStr = String(cmd);
  int activeCount = parseAndSetNozzles(cmdStr);
  
  if (activeCount == 0) return; // 유효하지 않은 명령어 필터링

  isRunning = true; 
  isSpraying = true; 
  sprayDuration = dur * 1000;
  prevMotorMillis = millis(); 
  startTimeMillis = millis(); 
  
  for (int i = 0; i < 4; i++) {
    if (activeNozzles[i]) {
      int targetPin = getPinFromCommand(i + 1);
      if (targetPin != -1) digitalWrite(targetPin, LOW);
    }
  }
  
  // 삼항 연산자를 활용한 재생 트랙 선택 로직 간소화
  int targetMusic = (music > 0 && music <= 20) ? music : ((cmd >= 10) ? 1 : cmd);
  playSound(targetMusic);

  lastWebMessage = "성공: " + txt; 
  if (!isWeatherMode) {
    updateDisplay((cmd >= 10) ? 0 : cmd, txt);
  }

  Serial.printf("\r\n\033[32m✅ 분사 실행: %s (명령:%d)\033[0m\r\n", txt.c_str(), cmd);
  showPrompt();
}

void checkNextionInput() {
  static String buf = ""; 
  while (nexSerial.available()) {
    char c = (char)nexSerial.read();
    
    lastActivityTime = millis(); // 화면 터치 시 타이머 리셋
    if (currentMode == MODE_SLEEP) wakeUpSystem(); 

    if (isalnum(c) || c == '_' || c == ' ') buf += c;
    if (buf == "M1" || buf == "M2" || buf == "M3" ||
        buf == "Y1" || buf == "Y2" || buf == "Y3" ||
        buf == "ST" || buf == "BM" ||
        (buf.startsWith("S") && buf.length() == 2)) {
      handleNextionCmd(buf);
      buf = "";
    }
    else if (buf.length() > 64) buf = ""; 
  }
}

void handleNextionCmd(const String &cmd) {
      if (cmd.startsWith("p0") || cmd.startsWith("t_weather") || cmd.startsWith("j0")) return;

      if (cmd == "M2" || cmd == "Y3") {
        setSystemMode(MODE_WEATHER, "Weather Mode");
        enterWeatherMode(false);
      }
      else if (cmd == "M1" || cmd == "Y1") {
        setSystemMode(MODE_MANUAL, "Manual Mode");
      }
      else if (cmd == "M3" || cmd == "Y2") {
        setSystemMode(MODE_SETTING, "Setting Mode");
      }
      else if (cmd == "ST") {
        blendModeEnabled = false;
        blendSelection = "";
        blendSprayActive = false;
        nexSend("b_blend.txt=\"blendON\"");
        setSystemMode(MODE_READY, "Stopped");
      }
      else if (cmd == "BM") {
        blendModeEnabled = !blendModeEnabled;
        blendSelection = "";
        blendSprayActive = false;

        if (blendModeEnabled) {
          nexSend("b_blend.txt=\"blendOFF\"");
          updateDisplay(0, "혼합 향 2개 선택");
          Serial.println("\r\n✅ 동시분사 모드 ON");
        } else {
          nexSend("b_blend.txt=\"blendON\"");
          updateDisplay(0, "수동 모드");
          Serial.println("\r\n✅ 동시분사 모드 OFF");
        }
      }
      else if (cmd.startsWith("S")) {
        int scent = cmd.substring(1).toInt();
        if (scent < 1 || scent > 4) return;

        setSystemMode(MODE_MANUAL);

        // 동시분사 모드가 아닐 때: 바로 단일 분사
        if (!blendModeEnabled) {
          runManualMode(String(scent));
          return;
        }

        // 동시분사 모드일 때: 향 2개 선택
        String scentStr = String(scent);

        // 중복 선택 방지
        if (blendSelection.indexOf(scentStr) == -1) {
          blendSelection += scentStr;
        }

        Serial.printf("\r\n[동시분사 선택] %s\r\n", blendSelection.c_str());

        if (blendSelection.length() == 1) {
          updateDisplay(0, "첫 번째 향 선택됨");
        }
        else if (blendSelection.length() == 2) {
          updateDisplay(0, "혼합 분사 시작");
          runManualMode(blendSelection);

          // 1회 실행 후 선택 초기화
          blendSelection = "";
        }
      }
    }

void nexSend(const String &cmd) { nexSerial.print(cmd); nexSerial.write(0xFF); nexSerial.write(0xFF); nexSerial.write(0xFF); }
void updateDisplay(int iconID, String text) { 
  if (currentMode == MODE_WEATHER && lastWeatherIconId >= 1 && lastWeatherIconId <= 4) iconID = lastWeatherIconId;
  if (currentMode == MODE_WEATHER && text.length() == 0) text = lastWeatherLabel;
  nexSend("p0.pic=" + String(iconID)); text.replace("\"", "'"); nexSend("t_weather.txt=\"" + text + "\"");
}
