// --- 전역 네트워크 세션 객체 (TLS 커넥션 유지용) ---
static WiFiClientSecure sharedClient;
static bool isSessionInit = false;

void initNetworkSession() {
  if (!isSessionInit) {
    sharedClient.setInsecure(); // SSL 인증서 검사 건너뛰기
    isSessionInit = true;
  }
}

// --- 중복 분사 제어 로직 통합 함수 ---
void triggerSpray(int cmd, int dur, int music, String txt, bool isWeatherMode = false) {
  forceAllOff();
  if (cmd == 1) activePin = PIN_SUNNY; 
  else if (cmd == 2) activePin = PIN_CLOUDY;
  else if (cmd == 3) activePin = PIN_RAIN; 
  else if (cmd == 4) activePin = PIN_SNOW;

  isRunning = true; 
  isSpraying = true; 
  sprayDuration = dur * 1000;
  prevMotorMillis = millis(); 
  startTimeMillis = millis(); 
  
  digitalWrite(activePin, LOW);
  
  if (music > 0 && music <= 20) playSound(music);
  else playSound(cmd);

  lastWebMessage = "성공: " + txt; 
  
  if (!isWeatherMode) {
    updateDisplay(cmd, txt);
  }
  Serial.printf(C_GREEN "✅ 분사 실행: %s (핀:%d)\r\n" C_RESET, txt.c_str(), activePin);
}

// ==========================================
// 넥션 디스플레이 및 유틸 함수들
// ==========================================
void checkNextionInput() {
  static String buf = ""; 
  
  while (nexSerial.available()) {
    char c = (char)nexSerial.read();
    if (isalnum(c) || c == '_' || c == ' ') { 
      buf += c;
    }

   if (buf == "M1" || buf == "M2" || buf == "M3" || 
        buf == "Y1" || buf == "Y2" || buf == "Y3" || 
        buf == "ST" ||
        (buf.startsWith("S") && buf.length() == 2)) {

      handleNextionCmd(buf);
      buf = "";
    }
    else if (buf.length() > 64) {
      buf = ""; 
    }
  }
}

void handleNextionCmd(const String &cmd) {
  if (cmd.startsWith("p0") || cmd.startsWith("t_region") || cmd.startsWith("j0")) return;

  bool isCommand = (cmd == "M1" || cmd == "M2" || cmd == "M3" || 
                  cmd.startsWith("S") || 
                  cmd == "Y1" || cmd == "Y2" || cmd == "Y3" ||
                  cmd == "ST");
  if (isCommand) {
    Serial.print("\r\033[K");
    Serial.printf(C_CYAN "[NX] 터치: %s\r\n" C_RESET, cmd.c_str());
  }

  if (cmd == "M2" || cmd == "Y3") enterWeatherMode(false);
  else if (cmd == "M1" || cmd == "Y1") {
    currentMode = 1;
    Serial.println(C_BLUE "--- [ Mode 1: 수동 ] ---" C_RESET);
    updateDisplay(0, "Manual Mode");
    showPrompt();
  }
  else if (cmd == "M3" || cmd == "Y2") {
    currentMode = 2;
    Serial.println(C_BLUE "--- [ Mode 2: 감성 ] ---" C_RESET);
    updateDisplay(0, "Emotion Mode");
    showPrompt();
  }
  else if (cmd == "ST") {
      Serial.println(C_RED "--- [ STOP ] ---" C_RESET);
      stopSystem();
      currentMode = 0;
      lastWebMessage = "정지";
      updateDisplay(0, "Stopped");
    }
  else if (cmd.startsWith("S")) {
    int scent = cmd.substring(1).toInt();
    if (scent >= 1 && scent <= 4) {
      currentMode = 1;
      lastWebMessage = "Nextion 수동 분사 S" + String(scent);
      Serial.printf(C_GREEN "[NX] 수동 향 %d 실행\r\n" C_RESET, scent);
      runManualMode(String(scent));
    }
  }
}

void nexSend(const String &cmd) { 
  nexSerial.print(cmd);
  nexSerial.write(0xFF); nexSerial.write(0xFF); nexSerial.write(0xFF); 
}

void updateDisplay(int iconID, String text) { 
  if (currentMode == 3 && lastWeatherIconId >= 1 && lastWeatherIconId <= 4) {
    iconID = lastWeatherIconId;
  }

  if (currentMode == 3) {
    if (text.length() == 0) text = lastWeatherLabel;
    if (text.length() == 0) text = "Weather";
  }

  nexSend("p0.pic=" + String(iconID));
  text.replace("\"", "'");
  nexSend("t_region.txt=\"" + text + "\"");
}

void updateTempHumi(float tempC, float humi) {
  nexSend("t_temp.txt=\"" + String(tempC, 1) + "C\"");
  nexSend("t_humi.txt=\"" + String(humi, 0) + "%\"");
}

void updateProgressBar(int val) { 
  nexSend("j0.val=" + String(constrain(val, 0, 100))); 
}

