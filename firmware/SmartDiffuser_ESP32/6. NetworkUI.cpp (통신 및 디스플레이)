void nexSend(const String &cmd) { 
  nexSerial.print(cmd);
  nexSerial.write(0xFF); nexSerial.write(0xFF); nexSerial.write(0xFF); 
}

void updateDisplay(int iconID, String text) { 
  // 1. 사진(아이콘) 변경 (p0)
  nexSend("p0.pic=" + String(iconID));
  // 2. 글자(텍스트) 변경 (t_region)
  text.replace("\"", "'"); // 따옴표 충돌 방지
  nexSend("t_region.txt=\"" + text + "\""); 
}

void updateProgressBar(int val) { 
  nexSend("j0.val=" + String(constrain(val, 0, 100))); 
}
