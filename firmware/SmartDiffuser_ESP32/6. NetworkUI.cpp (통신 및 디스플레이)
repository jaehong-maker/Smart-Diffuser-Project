  Serial.println("\r\n" C_CYAN "=== [System Diagnostics Dashboard] ===" C_RESET);
  Serial.printf("[Network] WiFi RSSI: %d dBm\r\n", WiFi.RSSI()); 
  Serial.printf("[Sensors] Weights: W1:%.1f W2:%.1f W3:%.1f W4:%.1f (g)\r\n", weights[0], weights[1], weights[2], weights[3]); 
  
  // ESP32 하드웨어 메모리 단편화 및 누수 검증 데이터
  Serial.printf("[Memory]  Free Heap: %d Bytes (Historical Min: %d Bytes)\r\n", ESP.getFreeHeap(), ESP.getMinFreeHeap());
  
  // FreeRTOS 태스크별 스택 여유 공간(High Water Mark) 추적
  if (NetworkTaskHandle != NULL) {
    Serial.printf("[Task 1]  NetworkTask Stack Watermark: %d Bytes\r\n", uxTaskGetStackHighWaterMark(NetworkTaskHandle));
  }
  if (SensorTaskHandle != NULL) {
    Serial.printf("[Task 2]  SensorTask Stack Watermark: %d Bytes\r\n", uxTaskGetStackHighWaterMark(SensorTaskHandle));
  }
  Serial.println(C_CYAN "======================================" C_RESET);
  
  printMainMenu(); 
}

