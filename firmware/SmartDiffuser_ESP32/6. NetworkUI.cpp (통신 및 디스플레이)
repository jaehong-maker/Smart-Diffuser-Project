void connectWiFi() {
  Serial.printf(C_YELLOW "[System] WiFi Connecting" C_RESET);
  WiFi.begin(ssid, password);
  int retry = 0;
  while (WiFi.status() != WL_CONNECTED && retry < 15) { delay(200); Serial.print("."); retry++; }
  if (WiFi.status() == WL_CONNECTED) {
    Serial.printf("\r\n" C_GREEN "Connected!\r\n" C_RESET);
    Serial.printf(C_CYAN "🌐 Web: http://%s/\r\n" C_RESET, WiFi.localIP().toString().c_str());
  } else { Serial.printf(C_RED "\r\nWiFi Failed.\r\n" C_RESET); }
}

void manageWiFi() {
  static bool wasConnected = true;
  if (millis() - lastCheckTime >= 1000) {
    lastCheckTime = millis();
    if (WiFi.status() != WL_CONNECTED) {
      if (wasConnected) {
        wasConnected = false; Serial.print("\r\033[K"); Serial.printf(C_RED "🚨 WiFi 끊김!\r\n" C_RESET);
        updateDisplay(0, "WiFi Lost"); WiFi.disconnect(); WiFi.reconnect(); showPrompt(); Serial.print(inputBuffer);
      }
    } else {
      if (!wasConnected) {
        wasConnected = true;
        Serial.print("\r\033[K"); Serial.printf(C_GREEN "✅ WiFi 복구!\r\n" C_RESET);
        updateDisplay(0, "WiFi OK"); showPrompt(); Serial.print(inputBuffer);
      }
    }
  }
}

void pollServer() {
  if (currentMode == 5) return;
  unsigned long now = millis();
  
  if (now - lastPollTime >= POLL_INTERVAL) {
    lastPollTime = now;
    if (WiFi.status() != WL_CONNECTED) return;
    
    initNetworkSession();
    HTTPClient http; // 지역 변수로 생성하여 독립성 확보

    if (http.begin(sharedClient, serverName)) {
      http.addHeader("Content-Type", "application/json");

      String payload = "{\"action\": \"POLL\", \"deviceId\": \"App_User\", \"weights\": [";
      for (int i=0; i<4; i++) {
        payload += String(weights[i], 1) + (i < 3 ? ", " : "]}");
      }

      int code = http.POST(payload);
      
      if (code == HTTP_CODE_OK) {
        JsonDocument doc; 
        DeserializationError error = deserializeJson(doc, http.getString()); // http 객체 사용
        
        if (error) {
          Serial.println(C_RED "⚠️ [APP] JSON 파싱 에러" C_RESET);
          http.end(); return;
        }
        
        int cmd = doc["spray"] | 0; 
        int music = doc["music"] | 0; 
        currentIntensity = doc["intensity"] | 2; 
        if (currentIntensity == 1) {
            REST_TIME = 9000; // 약: 3초 쏘고 9초 쉼
        } else if (currentIntensity == 2) {
            REST_TIME = 6000; // 중: 3초 쏘고 6초 쉼
        } else {
            REST_TIME = 3000; // 강: 3초 쏘고 3초 쉼
        }
        static int lastAppCmd = 0; 

        if (cmd > 0) {
          if (cmd >= 1 && cmd <= 4 && cmd == lastAppCmd && isRunning) {
             http.end(); return; 
          }
          lastAppCmd = cmd; 

          Serial.printf("\r\n" C_GREEN "📲 [APP] 명령: %d\r\n" C_RESET, cmd);
          
          if (cmd == 90) { stopSystem(); currentMode = 0; updateDisplay(0, "Reset"); http.end(); return; }
          if (cmd == 30) { 
              currentMode = 3;
              String region = doc["region"] | "";
              if (region.length() == 0) region = doc["target_region"] | "";
              if (region.length() > 0) lastWeatherRegion = region;

              lastWeatherCallMillis = millis() - WEATHER_INTERVAL; 
              updateDisplay(lastWeatherIconId, lastWeatherLabel);
              http.end(); return;
            }
          if (cmd >= 80 && cmd <= 82) {
            changeVolume((cmd == 80) ? 0 : (cmd == 81 ? currentVolume - 2 : currentVolume + 2)); 
            updateDisplay(0, "Volume Set"); lastWebMessage = "볼륨 조절 완료"; http.end(); return; 
          }

          triggerSpray(cmd, 3, music, "앱 제어 중...", false);
          showPrompt(); Serial.print(inputBuffer);
        } else {
          lastAppCmd = 0; 
        }
      } else if (code < 0) {
        Serial.printf(C_RED "⚠️ [APP] 서버 에러: %s\r\n" C_RESET, http.errorToString(code).c_str());
      }
      http.end(); // 세션 종료
    }
  }
}

void sendServerRequest(String payload) {
  if (WiFi.status() != WL_CONNECTED) { Serial.println("WiFi Err"); return; }
  
  initNetworkSession();
  HTTPClient http; // 지역 변수화

  if (!http.begin(sharedClient, serverName)) return;
  http.addHeader("Content-Type", "application/json");

  int code = http.POST(payload);
  if (code == HTTP_CODE_OK) {
    JsonDocument doc; 
    if (deserializeJson(doc, http.getString())) { // http 사용
       Serial.println(C_RED "⚠️ 서버 응답 JSON 오류" C_RESET);
       http.end(); return;
    }

    int cmd = doc["spray"] | 0;
    int dur = doc["duration"] | 3;
    String txt = doc["result_text"] | "명령 수신";
    currentIntensity = doc["intensity"] | 2; 
    if (currentIntensity == 1) {
        REST_TIME = 9000; // 약: 3초 쏘고 9초 쉼
    } else if (currentIntensity == 2) {
        REST_TIME = 6000; // 중: 3초 쏘고 6초 쉼
    } else {
        REST_TIME = 3000; // 강: 3초 쏘고 3초 쉼
    }
    
    String region = doc["region"] | "";
    if (region.length() == 0) region = doc["target_region"] | "";
    if (region.length() > 0) {
      lastWeatherRegion = region;
      Serial.printf(C_GREEN "[WEATHER] region 저장: %s\r\n" C_RESET, lastWeatherRegion.c_str());
    }

    if (doc["temp"].is<const char*>() && doc["humidity"].is<const char*>()) {
      updateTempHumi(String(doc["temp"].as<const char*>()).toFloat(), String(doc["humidity"].as<const char*>()).toFloat());
    }

    int music = doc["music"] | 0; 
    txt = txt + " [M: " + String(music) + "]";
    Serial.printf("\r\n✅ 응답: %s\r\n", txt.c_str());

    if (currentMode == 3) {
      int iconId = 1;
      String w = doc["weather"] | txt;
      String weatherLabel = "Sunny";
      if (w.indexOf("눈") >= 0) { iconId = 4; weatherLabel = "Snowy"; }
      else if (w.indexOf("비") >= 0) { iconId = 3; weatherLabel = "Rainy"; }
      else if (w.indexOf("흐") >= 0 || w.indexOf("구름") >= 0) { iconId = 2; weatherLabel = "Cloudy"; }
      else if (w.indexOf("맑") >= 0) { iconId = 1; weatherLabel = "Sunny"; }

      lastWeatherIconId = iconId;
      lastWeatherLabel = weatherLabel;
      updateDisplay(iconId, lastWeatherLabel);
    }

    if (cmd > 0) {
      if (cmd >= 80 && cmd <= 82) {
        changeVolume((cmd == 80) ? 0 : (cmd == 81 ? currentVolume - 2 : currentVolume + 2)); 
        updateDisplay(0, "Volume Set"); lastWebMessage = "볼륨 조절 완료"; http.end(); return; 
      }
      triggerSpray(cmd, dur, music, txt, (currentMode == 3));
    } else {
      Serial.printf(C_YELLOW "⚠️ 대기: %s\r\n" C_RESET, txt.c_str());
      lastWebMessage = txt;
      if (currentMode == 3) { forceAllOff(); isRunning = false; isSpraying = false; activePin = -1; }
      else { stopSystem(); updateDisplay(0, txt); }
    }
  }
  http.end(); // 세션 종료
  showPrompt(); Serial.print(inputBuffer);
}

// ==========================================================
// 음성 제어 관련 로직
// ==========================================
bool recordAudio(uint8_t** audioBuffer, uint32_t* totalSize) {
  uint32_t dataSize = SAMPLE_RATE * RECORD_TIME * 2;
  *totalSize = sizeof(WavHeader) + dataSize;

  if (ESP.getFreeHeap() < *totalSize + 20000) {
    Serial.println(C_RED "⚠️ 메모리 부족! 기기를 재부팅해주세요." C_RESET);
    updateDisplay(0, "Memory Full"); return false;
  }

  Serial.printf(C_YELLOW "\r\n[Voice] 🎤 녹음 시작 (2초)...\r\n" C_RESET);
  *audioBuffer = (uint8_t*)malloc(*totalSize);
  if (*audioBuffer == NULL) return false;

  WavHeader header; 
  memcpy(header.riff, "RIFF", 4); header.overall_size = *totalSize - 8; 
  memcpy(header.wave, "WAVE", 4); memcpy(header.fmt_chunk_marker, "fmt ", 4); 
  header.length_of_fmt = 16; header.format_type = 1; header.channels = 1; 
  header.sample_rate = SAMPLE_RATE; header.byterate = SAMPLE_RATE * 2; 
  header.block_align = 2; header.bits_per_sample = 16; 
  memcpy(header.data_chunk_header, "data", 4); header.data_size = dataSize; 
  memcpy(*audioBuffer, &header, sizeof(WavHeader));

  size_t bytesRead = 0;
  i2s_read(I2S_PORT, (void*)(*audioBuffer + sizeof(WavHeader)), dataSize, &bytesRead, portMAX_DELAY);

  int16_t* samples = (int16_t*)(*audioBuffer + sizeof(WavHeader));
  int numSamples = dataSize / 2;
  float lastX = 0, lastY = 0, dcAlpha = 0.999, preAlpha = 0.97;     
  int16_t maxPeak = 0, prevSample = 0;

  for (int i = 0; i < numSamples; i++) {
    int16_t currentX = samples[i];
    float currentY = (float)currentX - lastX + dcAlpha * lastY;
    lastX = (float)currentX; lastY = currentY;
    int32_t emphasized = (int32_t)(currentY - (preAlpha * (float)prevSample));
    prevSample = (int16_t)currentY;
    emphasized = constrain(emphasized, -32768, 32767);
    samples[i] = (int16_t)emphasized;
    if (abs(samples[i]) > maxPeak) maxPeak = abs(samples[i]);
  }

  long sumVolume = 0;
  if (maxPeak > 500) { 
    float gain = constrain(30000.0 / (float)maxPeak, 1.0, 15.0);
    for (int i = 0; i < numSamples; i++) {
      int32_t boosted = constrain((int32_t)(samples[i] * gain), -32768, 32767);
      samples[i] = (int16_t)boosted;
      sumVolume += abs(samples[i]);
    }
  }

  if (sumVolume / numSamples < 300) { 
    Serial.println(C_RED "→ 🤫 소리가 너무 작습니다 (취소)" C_RESET);
    updateDisplay(0, "Too Quiet"); return false;
  }

  Serial.println(C_GREEN "→ ✅ 필터링 완료" C_RESET);
  return true;
}

bool sendAudioToServer(uint8_t* audioBuffer, uint32_t totalSize, String& response) {
  Serial.println(C_GREEN "→ 🗣️ 전송 중..." C_RESET); updateDisplay(0, "Thinking...");
  esp_task_wdt_delete(NULL); 
  bool success = false;
  
  initNetworkSession();
  HTTPClient http; // 지역 변수화
  http.setTimeout(10000); // 대용량 데이터 전송을 위해 타임아웃 넉넉히 설정

  if (http.begin(sharedClient, serverName)) {
    http.addHeader("Content-Type", "audio/wav");
    int httpCode = http.POST(audioBuffer, totalSize);
    if (httpCode > 0) {
      response = http.getString();
      Serial.printf(C_GREEN "✅ 응답 수신 완료\r\n" C_RESET);
      success = true;
    } else {
      Serial.printf("HTTP Error: %s\n", http.errorToString(httpCode).c_str());
      updateDisplay(0, "Network Error");
    }
    http.end(); // 세션 종료
  } else { Serial.println("Conn Fail"); updateDisplay(0, "Conn Fail"); }

  esp_task_wdt_add(NULL);
  return success;
}

void executeVoiceCommand(String jsonResponse) {
  JsonDocument doc; 
  if (deserializeJson(doc, jsonResponse)) {
    Serial.println(C_RED "⚠️ 파싱 실패" C_RESET); return;
  }

  int cmd = doc["spray"] | -1; 
  int dur = doc["duration"] | 3;
  String txt = doc["result_text"] | "명령 수신";
  String transcript = doc["transcript"] | ""; 
  String msg = doc["message"] | "명령 수신"; 
  int music = doc["music"] | 0;

  if (cmd >= 1 && cmd <= 4) {
    triggerSpray(cmd, dur, music, txt, false);
  } else if (cmd == 0) { 
    if (transcript == "SILENCE" || msg.indexOf("묵음") >= 0 || msg.indexOf("실패") >= 0 || txt.indexOf("묵음") >= 0) {
       Serial.println("\r\n[Voice] 묵음 패스. 기존 작동 유지.");
       updateDisplay(0, "Keep Running");
    } else {
       stopSystem(); lastWebMessage = txt; updateDisplay(0, txt); 
       Serial.println(C_YELLOW "🛑 시스템 정지" C_RESET);
    }
  } else {
    Serial.printf(C_CYAN "ℹ️ 상태 유지 (cmd:%d)\r\n" C_RESET, cmd);
  }
}

void recordAndSendVoice() {
  if (WiFi.status() != WL_CONNECTED) { Serial.println("WiFi Disconnected"); return; }

  uint8_t* audioBuffer = NULL;
  uint32_t totalSize = 0;

  if (recordAudio(&audioBuffer, &totalSize)) {
    String response = "";
    if (sendAudioToServer(audioBuffer, totalSize, response)) {
      executeVoiceCommand(response);
    }
  }

  if (audioBuffer != NULL) { free(audioBuffer); audioBuffer = NULL; }
  showPrompt();
}

