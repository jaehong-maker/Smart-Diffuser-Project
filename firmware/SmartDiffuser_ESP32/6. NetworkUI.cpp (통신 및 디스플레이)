  for (;;) {
    EventBits_t bits = xEventGroupWaitBits(networkEventGroup, BIT_SEND_POLL | BIT_SEND_VOICE | BIT_SEND_REQUEST, pdTRUE, pdFALSE, portMAX_DELAY);
