void autoWeatherScheduler() {
  if (currentMode != MODE_WEATHER || isRunning) return; // 2 -> MODE_WEATHER
  if (millis() - lastWeatherCallMillis >= WEATHER_INTERVAL) {
    lastWeatherCallMillis = millis(); 
    sendServerRequest("{\"mode\": \"weather\", \"region\": \"" + lastWeatherRegion + "\"}");
  }
}

