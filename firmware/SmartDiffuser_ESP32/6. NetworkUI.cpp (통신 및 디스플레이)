void checkNextionInput() {
  static String buf = ""; static unsigned long lastRxTime = 0;
  while (nexSerial.available()) {
    char c = (char)nexSerial.read();
    if (isalnum(c) || c == '_' || c == ' ') { buf += c;
      if (buf.length() > 64) buf = ""; }
    lastRxTime = millis();
  }
  if (buf.length() > 0 && (millis() - lastRxTime > 50)) {
    buf.trim();
    if (buf.length() > 0) handleNextionCmd(buf);
    buf = "";
  }
}

void handleNextionCmd(const String &cmd) {
  if (cmd.startsWith("p0") || cmd.startsWith("t_region") || cmd.startsWith("j0")) return;
  bool isCommand = false;
  if (cmd == "M1" || cmd == "M2" || cmd == "M3" || cmd.startsWith("S")) isCommand = true;
  if (cmd == "Y1" || cmd == "Y2" || cmd == "Y3") isCommand = true;
  if (isCommand) {
    Serial.print("\r\033[K"); Serial.printf(C_CYAN "[NX] 터치: %s\r\n" C_RESET, cmd.c_str());
  }
  if (cmd == "M2" || cmd == "Y3") { enterWeatherMode(false);
  }
  else if (cmd == "M1" || cmd == "Y1") { currentMode = 1;
    Serial.println(C_BLUE "--- [ Mode 1: 수동 ] ---" C_RESET); showPrompt();
  }
  else if (cmd == "M3" || cmd == "Y2") { currentMode = 2;
    Serial.println(C_BLUE "--- [ Mode 2: 감성 ] ---" C_RESET); showPrompt(); }
  else if (cmd.startsWith("S")) { int scent = cmd.substring(1).toInt();
    if (scent >= 1 && scent <= 4) runManualMode(String(scent)); }
}

