// ★ 추가: MAC 주소 기반 고유 디바이스 ID 생성 함수
String getUniqueDeviceId() {
  String mac = WiFi.macAddress();
  mac.replace(":", "");
  return "ESP_" + mac;
}

void initNetworkSession() {
  if (!isSessionInit) { sharedClient.setInsecure(); isSessionInit = true; }
}

void rememberWeatherRegion(const String &region) {
  if (region.length() == 0 || region == lastWeatherRegion) return;

  lastWeatherRegion = region;
  prefs.putString("last_region", lastWeatherRegion);
  Serial.printf(C_CYAN "\r\n[Weather] Saved region updated: %s\r\n" C_RESET, lastWeatherRegion.c_str());
}

String buildWeatherRequestPayload(const String &region) {
  JsonDocument reqDoc;
  reqDoc["mode"] = "weather";
  if (region.length() > 0) {
    reqDoc["region"] = region;
  }

  // 🔥 날씨 모드에서도 현재 무게 배열을 추가해서 서버로 같이 보냄!
  JsonArray wArray = reqDoc["weights"].to<JsonArray>();
  for (int i = 0; i < 4; i++) {
    wArray.add((float)((int)(weights[i] * 10)) / 10.0);
  }

  String payload;
  payload.reserve(128); // JSON 크기가 늘어났으니 메모리 블록 128로 세팅
  serializeJson(reqDoc, payload);
  return payload;
}

static String attachDeviceIdIfMissing(const String &payload) {
  JsonDocument doc;
  DeserializationError err = deserializeJson(doc, payload);
  if (err || !doc.is<JsonObject>()) return payload;

  if (doc["deviceId"].isNull()) {
    doc["deviceId"] = deviceId; // ★ 수정: 사용자가 설정한 기기 ID 변수를 전송
  }

  String normalized;
  normalized.reserve(payload.length() + 32);
  serializeJson(doc, normalized);
  return normalized;
}

// --- NetworkUI.cpp 파일의 triggerSpray 함수 수정 ---
void triggerSpray(int cmd, int dur, int music, String txt, bool isWeatherMode) {
  forceAllOff();
  
  // DRY 원칙 적용: SystemLogic 모듈의 파싱 및 노즐 활성화 유틸리티 재사용
  String cmdStr = String(cmd);
  int activeCount = parseAndSetNozzles(cmdStr);
  
  if (activeCount == 0) return; // 유효하지 않은 명령어 필터링

  if (currentMode == MODE_AMBIENT) {
    if (lastAmbientScent == 0) {
      lastAmbientScent = cmd; // 최초 향 저장
    } else if (lastAmbientScent != cmd) {
      Serial.printf(C_MAGENTA "\r\n[향기 쿨타임] 추천 향이 %d번에서 %d번으로 변경되었습니다. 이번 턴 분사는 생략!\r\n" C_RESET, lastAmbientScent, cmd);
      lastAmbientScent = cmd; 
      return; // 분사 모터를 돌리지 않고 종료
    }
  }

  isRunning = true; 
  isSpraying = true; 
  sprayDuration = dur * 1000;
  prevMotorMillis = millis(); 
  startTimeMillis = millis(); 
  
  for (int i = 0; i < 4; i++) {
    if (activeNozzles[i]) {
      int targetPin = getPinFromCommand(i + 1);
      if (targetPin != -1) digitalWrite(targetPin, LOW);
    }
  }
  
  // 삼항 연산자를 활용한 재생 트랙 선택 로직 간소화
  if (music != 0 && currentMode != MODE_AMBIENT) { 
    int targetMusic = (music > 0 && music <= 20) ? music : ((cmd >= 10) ? 1 : cmd);
    playSound(targetMusic);
  }

  lastWebMessage = "성공: " + txt; 
  if (!isWeatherMode) {
    updateDisplay((cmd >= 10) ? 0 : cmd, txt);
  }

  Serial.printf("\r\n\033[32m✅ 분사 실행: %s (명령:%d)\033[0m\r\n", txt.c_str(), cmd);
  showPrompt();
}

void checkNextionInput() {
  static String buf = ""; 
  while (nexSerial.available()) {
    char c = (char)nexSerial.read();
    
    lastActivityTime = millis(); // 화면 터치 시 타이머 리셋
    if (currentMode == MODE_SLEEP) wakeUpSystem(); 

    if (isalnum(c) || c == '_' || c == ' ') buf += c;
    if (buf == "M1" || buf == "M2" || buf == "M3" ||
        buf == "Y1" || buf == "Y2" || buf == "Y3" ||
        buf == "ST" || buf == "BM" || buf == "RE" || buf == "OF" ||
        (buf.startsWith("S") && buf.length() == 2)) {
      handleNextionCmd(buf);
      buf = "";
    }
    else if (buf.length() > 64) buf = ""; 
  }
}

void handleNextionCmd(const String &cmd) {
  if (cmd.startsWith("p0") || cmd.startsWith("t_weather") || cmd.startsWith("j0")) return;

  if (cmd == "M2" || cmd == "Y3") {
    enterWeatherMode(true);
  }
  else if (cmd == "M1" || cmd == "Y1") {
    setSystemMode(MODE_MANUAL, "Manual Mode");
  }
  else if (cmd == "M3" || cmd == "Y2") {
    setSystemMode(MODE_SETTING, "Setting Mode");
  }
  else if (cmd == "ST") {
    setSystemMode(MODE_READY, "Stopped");

    }
  else if (cmd == "BM") {
    blendModeEnabled = !blendModeEnabled;
    blendSelection = "";
    blendSprayActive = false;

    if (blendModeEnabled) {
      nexSend("b_blend.txt=\"blendOFF\"");
      updateDisplay(0, "Pick 2 scents");
      Serial.println("\r\n[BLEND] ON");
    } else {
      nexSend("b_blend.txt=\"blendON\"");
      updateDisplay(0, "Manual Mode");
      Serial.println("\r\n[BLEND] OFF");
    }
  }
  else if (cmd.startsWith("S")) {
    int scent = cmd.substring(1).toInt();
    if (scent < 1 || scent > 4) return;

    Serial.printf("\r\n[S BUTTON] %s\r\n", cmd.c_str());

    currentMode = MODE_MANUAL;

    if (!blendModeEnabled) {
      runManualMode(String(scent));
      return;
    }

    String scentStr = String(scent);

    if (blendSelection.indexOf(scentStr) == -1) {
      blendSelection += scentStr;
    }

    if (blendSelection.length() == 1) {
      updateDisplay(0, "1st scent selected");
    }
    else if (blendSelection.length() == 2) {
      runManualMode(blendSelection);
      blendSelection = "";
      updateDisplay(0, "Blending Mode");
    }
  }
  else if (cmd == "RE") {
    Serial.println("Wi-Fi 설정 초기화 및 재부팅!");
    WiFiManager wifiManager;
    wifiManager.resetSettings(); // 플래시 메모리 와이파이 정보 삭제
    ESP.restart(); // 재부팅 (재부팅되면 저장된게 없으니 다시 무한 대기 모드로 진입)
  }
}

