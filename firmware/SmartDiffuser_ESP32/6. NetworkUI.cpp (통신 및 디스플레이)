void changeVolume(int vol) { currentVolume = constrain(vol, 0, 30); myDFPlayer.volume(currentVolume); Serial.printf("\r\033[K" C_GREEN "🔊 볼륨: %d\r\n" C_RESET, currentVolume); showPrompt(); }

// [수정 후]
void initOTA() { 
  ArduinoOTA.setHostname("SmartDiffuser"); 
  ArduinoOTA.setPassword("1234"); // ★ OTA 무선 업로드 패스워드 추가
  
  ArduinoOTA.onStart([]() {
    forceAllOff(); // 진행 중 안전을 위해 모든 핀 출력을 즉시 차단
    updateDisplay(0, "OTA Updating...");
    Serial.println("\r\n[OTA] 무선 업데이트 시작...");
  });
  
  ArduinoOTA.onEnd([]() {
    updateDisplay(0, "Update Success!");
    Serial.println("\r\n[OTA] 무선 업데이트 완료!");
  });
  
  ArduinoOTA.onProgress([](unsigned int progress, unsigned int total) {
    int percent = (progress / (total / 100));
    updateProgressBar(percent); // 디스플레이의 j1(프로그레스 바) 실시간 연동
    Serial.printf("[OTA] 진행률: %u%%\r", percent);
  });
  
  ArduinoOTA.onError([](ota_error_t error) {
    updateDisplay(0, "OTA Error!");
    Serial.printf("\r\n[OTA] 에러 발생 코드: [%u]\r\n", error);
  });
  
  ArduinoOTA.begin(); 
}

void handleOTA() { ArduinoOTA.handle(); }
