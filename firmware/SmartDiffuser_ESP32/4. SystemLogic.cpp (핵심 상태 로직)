#include "Globals.h"

// --- 서브 루틴: 시스템 기상 ---
void wakeUpSystem() {
  if (currentMode != MODE_SLEEP) return;
  lastActivityTime = millis();
  nexSend("sleep=0"); 
  delay(100);
  Serial.println(C_GREEN "\r\n☀️ 시스템 기상! Wi-Fi 재연결 중...\r\n" C_RESET);
  WiFi.mode(WIFI_STA);
  connectWiFi();
  setSystemMode(MODE_READY, "System Ready");
  printMainMenu();
}

// --- 서브 루틴: 모닝콜 알람 체크 ---
void checkAlarm() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return; 

  if (timeinfo.tm_hour == alarmHour && timeinfo.tm_min == alarmMinute) {
    if (!alarmTriggeredToday) {
      alarmTriggeredToday = true;
      if (currentMode == MODE_SLEEP) wakeUpSystem(); 
      
      Serial.println(C_YELLOW "\r\n⏰ [모닝콜] 기상 시간입니다! 아침 분사 시작!\r\n" C_RESET);
      triggerSpray(1, 3, 1, "Morning Call", false); 
    }
  } else {
    alarmTriggeredToday = false; 
  }
}

// --- 서브 루틴: 오디오 큐 이벤트 처리 ---
void processAudioEvents() {
  int eventCode = 0;
  if (audioEventQueue != NULL && xQueueReceive(audioEventQueue, &eventCode, 0) == pdTRUE) {
    if (eventCode == 1) { 
      SystemMode prev = currentMode;
      setSystemMode(MODE_VOICE, "Voice Command");
      recordAndSendVoice(); 
      setSystemMode(isRunning ? prev : MODE_READY);
      showPrompt(); Serial.print(inputBuffer);
    } else if (eventCode == 2) { 
      wakeUpSystem();
    }
  }
}

// --- 서브 루틴: 스마트 절전 관리 ---
void manageSleepState() {
  if (currentMode == MODE_READY && (millis() - lastActivityTime > SLEEP_TIMEOUT)) {
    setSystemMode(MODE_SLEEP, "");
    WiFi.disconnect(true);
    WiFi.mode(WIFI_OFF);
    nexSend("sleep=1"); 
    Serial.println(C_YELLOW "\r\n🌙 스마트 절전 모드 진입 (Wi-Fi, 디스플레이 OFF)\r\n" C_RESET);
  }
}

// --- 서브 루틴: 향수 잔여량 경고 ---
void checkFluidLevels() {
  static unsigned long lastWarningTime = 0;
  if (currentMode == MODE_READY && (millis() - lastWarningTime > 10000)) { 
    lastWarningTime = millis();
    String warningMsg = "";
    for (int i = 0; i < 4; i++) {
      if (weights[i] > 0.5 && weights[i] < WEIGHT_THRESHOLD) {
        warningMsg += String(i + 1) + " ";
      }
    }
    if (warningMsg != "") {
      updateDisplay(0, "⚠️ Refill: " + warningMsg); 
      showPrompt();
    }
  }
}

// --- 시스템 초기화 ---
void initSystem() {
  Serial.begin(115200); Serial.setTimeout(5000);
  nexSerial.begin(9600, SERIAL_8N1, NEXTION_RX_PIN, NEXTION_TX_PIN);
  delay(300); nexSend("bauds=9600"); delay(100); nexSend("dim=100");    
  
  esp_task_wdt_deinit();
  esp_task_wdt_config_t wdt_config = { .timeout_ms = 60000, .idle_core_mask = (1 << 0) | (1 << 1), .trigger_panic = true };
  esp_task_wdt_init(&wdt_config); esp_task_wdt_add(NULL);

  pinMode(PIN_SUNNY, OUTPUT); pinMode(PIN_CLOUDY, OUTPUT);
  pinMode(PIN_RAIN, OUTPUT); pinMode(PIN_SNOW, OUTPUT); pinMode(PIN_LED, OUTPUT);
  forceAllOff();

  Serial.print("\r\n\r\n");
  Serial.printf(C_MAGENTA "****************************************\r\n" C_RESET);
  Serial.printf(C_BOLD    " 🚀 SMART DIFFUSER V12.5.0 (EEPROM ALARM) \r\n" C_RESET);
  Serial.printf(C_MAGENTA "****************************************\r\n" C_RESET);

  mySoftwareSerial.begin(9600, SERIAL_8N1, DFPLAYER_RX_PIN, DFPLAYER_TX_PIN);
  if (!myDFPlayer.begin(mySoftwareSerial)) Serial.println("Audio Fail");

  initMicrophone();

  // ★ 저장소에서 알람 시간 불러오기 추가!
  prefs.begin("diffuser", false);
  calibration_factor = prefs.getFloat("cal_factor", 430.0);
  currentVolume = prefs.getInt("volume", 20); myDFPlayer.volume(currentVolume);
  alarmHour = prefs.getInt("al_h", 7);
  alarmMinute = prefs.getInt("al_m", 30);

  for (int i = 0; i < 4; i++) {
    scales[i].begin(LOADCELL_DT[i], LOADCELL_SCK[i]);
    scales[i].set_scale(calibration_factor); scales[i].tare();
  }

  connectWiFi();
  
  configTime(9 * 3600, 0, "pool.ntp.org", "time.nist.gov");
  Serial.printf(C_CYAN "🌐 인터넷 시간 완료! (현재 알람 설정: %02d시 %02d분)\r\n" C_RESET, alarmHour, alarmMinute);

  audioEventQueue = xQueueCreate(5, sizeof(int));
  networkEventGroup = xEventGroupCreate();
  initOTA(); webServer.begin(); bootAnimation();
  
  lastActivityTime = millis(); 
  setSystemMode(MODE_READY, "System Ready");
  printMainMenu();

  xTaskCreatePinnedToCore(networkTaskLoop, "NetworkTask", 8192, NULL, 1, &NetworkTaskHandle, 1);
  xTaskCreatePinnedToCore(sensorTaskLoop, "SensorTask", 8192, NULL, 1, &SensorTaskHandle, 0);
}

// --- 메인 루프 ---
void runSystem() {
  esp_task_wdt_reset();
  handleOTA();
  checkNextionInput();

  if (currentMode == MODE_VISUAL) { runSoundVisualizer(); checkSerialInput(); return; }
  if (currentMode == MODE_REACTIVE) { runSoundReaction(); checkSerialInput(); return; }
  
  processAudioEvents();
  manageSleepState();

  if (currentMode == MODE_SLEEP) { 
    checkAlarm(); 
    checkSerialInput(); 
    return; 
  } 

  manageWiFi(); 
  systemHeartbeat(); 
  handleWebClient(); 
  autoWeatherScheduler(); 
  pollServer(); 
  monitorWeight();
  
  checkAlarm(); 
  checkFluidLevels(); 

  if (currentMode == MODE_DEMO) runAutoDemoLoop(); 
  else if (isRunning) { runSprayLogic(); checkSafety(); } 

  checkSerialInput();
}

// --- 시리얼 입력 감시 ---
void checkSerialInput() {
  if (Serial.available() <= 0) return;
  
  lastActivityTime = millis(); 
  if (currentMode == MODE_SLEEP) { wakeUpSystem(); return; }

  if (currentMode == MODE_REACTIVE) {
    char c = Serial.read(); if (c == '\n' || c == '\r') return;
    if (c == '+') { soundThreshold += 2; Serial.printf("\r\n🆙 감도: %d dB\r\n", soundThreshold); }
    else if (c == '-') { soundThreshold -= 2; Serial.printf("\r\n⬇️ 감도: %d dB\r\n", soundThreshold); }
    else if (c == '0') setSystemMode(MODE_READY, "Stopped");
    return;
  }

  if (currentMode == MODE_SETTING) {
    char c = Serial.read(); if (c == '\n' || c == '\r') return;
    if (c == '+') { calibration_factor += 10; for(int i=0; i<4; i++) scales[i].set_scale(calibration_factor); printCalibrationInfo(); }
    else if (c == '-') { calibration_factor -= 10; for(int i=0; i<4; i++) scales[i].set_scale(calibration_factor); printCalibrationInfo(); }
    else if (c == 't') { for(int i=0; i<4; i++) scales[i].tare(); Serial.println("영점 완료"); }
    else if (c == 's') { prefs.putFloat("cal_factor", calibration_factor); Serial.println("저장 완료"); }
    else if (c == 'p') {
        String payload = "{\"action\": \"POLL\", \"weights\": [";
        payload += String(weights[0], 1) + ", " + String(weights[1], 1) + ", " + String(weights[2], 1) + ", " + String(weights[3], 1) + "]}";
        Serial.println("\r\n🚀 [JSON 미리보기]: " + payload);
    }
    else if (c == '0') setSystemMode(MODE_READY, "Main Menu");
    return;
  }

  while (Serial.available() > 0) {
    char c = Serial.read();
    if (c == '\n' || c == '\r') {
      if (inputBuffer.length() > 0) {
        
        // ★ 알람 세팅 명령어 추가 (예: A0730 -> 7시 30분)
        if (inputBuffer.startsWith("A") && inputBuffer.length() == 5) {
          alarmHour = inputBuffer.substring(1, 3).toInt();
          alarmMinute = inputBuffer.substring(3, 5).toInt();
          prefs.putInt("al_h", alarmHour);
          prefs.putInt("al_m", alarmMinute);
          Serial.printf(C_GREEN "\r\n⏰ 알람 시간 변경: %02d시 %02d분 저장 완료!\r\n" C_RESET, alarmHour, alarmMinute);
          showPrompt();
        }
        else if (inputBuffer == "0") setSystemMode(MODE_READY, "Stopped");
        else handleInput(inputBuffer);
        
        inputBuffer = "";
      }
    } else if (c == '\b' || c == 0x7F) {
      if (inputBuffer.length() > 0) { inputBuffer.remove(inputBuffer.length() - 1); redrawInputLine(inputBuffer); }
    } else { inputBuffer += c; redrawInputLine(inputBuffer); }
  }
}

// --- 통합 입력 처리 ---
void handleInput(String input) {
  if (currentMode == MODE_READY) {
    if (input == "1")      setSystemMode(MODE_MANUAL, "Manual Mode");
    else if (input == "2") setSystemMode(MODE_WEATHER, "Weather Mode");
    else if (input == "3") setSystemMode(MODE_SETTING, "Setting Mode");
    else if (input == "4") { demoStep = 0; setSystemMode(MODE_DEMO, "Demo Mode"); }
    else if (input == "5") { setSystemMode(MODE_VOICE); recordAndSendVoice(); setSystemMode(MODE_READY, "Main Menu"); printMainMenu(); }
    else if (input == "6") setSystemMode(MODE_VISUAL, "Visualizer");
    else if (input == "7") setSystemMode(MODE_REACTIVE, "Sound Reaction");
    else if (input == "8") printDashboard();
    else { Serial.println(C_RED "Unknown Command" C_RESET); printMainMenu(); }
  } 
  else if (currentMode == MODE_MANUAL) {
    if (input == "+") changeVolume(currentVolume + 2); 
    else if (input == "-") changeVolume(currentVolume - 2); 
    else runManualMode(input); 
  }
  else if (currentMode == MODE_WEATHER) {
    lastWeatherRegion = input;
    updateDisplay(0, "Checking " + input); 
    sendServerRequest("{\"mode\": \"weather\", \"region\": \"" + input + "\"}");
  }
}

// --- 동작 제어 헬퍼 함수들 ---
void runManualMode(String input) { 
  int cmd = input.toInt();
  int targetPin = getPinFromCommand(cmd);
  if (targetPin != -1) {
    forceAllOff(); activePin = targetPin; isRunning = true; isSpraying = true;
    sprayDuration = 3000; prevMotorMillis = millis(); startTimeMillis = millis();
    digitalWrite(activePin, LOW); playSound(cmd);
    updateDisplay(cmd, "Manual Run");
  } else if (input == "0") { setSystemMode(MODE_READY, "Stopped"); }
}

void enterWeatherMode(bool runNow) {
  setSystemMode(MODE_WEATHER, "Weather Mode");
  Serial.println(C_YELLOW "👉 지역명을 입력하세요" C_RESET);
  if (runNow) sendServerRequest("{\"mode\": \"weather\", \"region\": \"" + lastWeatherRegion + "\"}");
}

void runSprayLogic() { 
  if (activePin == -1) return;

  if (isSpraying) {
    if (millis() - prevMotorMillis >= sprayDuration) {
      digitalWrite(activePin, HIGH); isSpraying = false; prevMotorMillis = millis();
      if (currentMode == MODE_MANUAL) { setSystemMode(MODE_READY, "Ready"); return; }
      updateDisplay((currentMode == MODE_WEATHER) ? lastWeatherIconId : 0, "Resting...");
    }
  } else {
    if (millis() - prevMotorMillis >= REST_TIME) {
      forceAllOff(); digitalWrite(activePin, LOW); isSpraying = true; prevMotorMillis = millis();
      int icon = 0;
      if (activePin == PIN_SUNNY) icon = 1; else if (activePin == PIN_CLOUDY) icon = 2;
      else if (activePin == PIN_RAIN) icon = 3; else if (activePin == PIN_SNOW) icon = 4;
      updateDisplay(icon, "Spraying...");
    }
  }
}

void runAutoDemoLoop() { 
  if (millis() - prevDemoMillis >= 4000) {
    prevDemoMillis = millis(); forceAllOff(); demoStep++;
    if (demoStep > 4) demoStep = 1;
    int targetPin = getPinFromCommand(demoStep);
    if (targetPin != -1) digitalWrite(targetPin, LOW); 
    playSound(demoStep); updateDisplay(demoStep, "Demo Mode");
  }
}

void checkSafety() {
  if (millis() - startTimeMillis > MAX_RUN_TIME) { setSystemMode(MODE_READY, "Safety Timeout"); }
}

void setSystemMode(SystemMode mode, String msg) { 
  currentMode = mode;
  if (msg != "") {
    Serial.printf(C_CYAN "\r\n[Mode] %s\r\n" C_RESET, msg.c_str());
    updateDisplay(0, msg);
  }
  if (mode == MODE_READY) stopSystem();
}
