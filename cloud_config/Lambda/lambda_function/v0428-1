            mapping_data = body.get("mapping")
            
            if mapping_data:
                normalized = db_utils.save_spray_mapping(device_id, mapping_data, u_email)
                if normalized:
                    return {"statusCode": 200, "headers": {"Content-Type": "application/json"}, "body": json.dumps({"spray": 0, "message": "향기 배치 설정 완료", "result_text": "OK"}, ensure_ascii=False)}
            
            return {"statusCode": 200, "headers": {"Content-Type": "application/json"}, "body": json.dumps({"spray": 0, "message": "포맷 오류", "result_text": "FAIL"}, ensure_ascii=False)}
        except Exception as e:
            return {"statusCode": 500, "body": str(e)}

    # [ACTION] SET_INTENSITY
    elif action == "SET_INTENSITY":
        try:
            intensity_val = int(body.get("intensity", 2))
            db_utils.state_table.update_item(
                Key={'deviceId': device_id},
                UpdateExpression="set intensity = :i",
                ExpressionAttributeValues={':i': intensity_val}
            )
            return {
                "statusCode": 200,
                "headers": {"Content-Type": "application/json"},
                "body": json.dumps({"spray": 0, "message": f"강도 {intensity_val}단계 설정 완료", "result_text": "OK"}, ensure_ascii=False)
            }
        except Exception as e:
            return {"statusCode": 500, "body": str(e)}

    # [ACTION] FEEDBACK
    elif action == "FEEDBACK":
        ambient_context = str(body.get("ambient_context", "") or "").strip()
        feedback_context = str(body.get("context", "") or "").strip()
        feedback_data = str(body.get("data", "") or "").strip()

        if not ambient_context and feedback_context.startswith("Ambient_"):
            ambient_context = feedback_context[len("Ambient_"):]

        if not ambient_context and body.get("mode") == "ambient":
            if feedback_context:
                ambient_context = feedback_context
            elif feedback_data:
                feedback_parts = feedback_data.split("_", 1)
                ambient_context = feedback_parts[1] if len(feedback_parts) > 1 else feedback_data

        if ambient_context.startswith("Ambient_"):
            ambient_context = ambient_context[len("Ambient_"):]

        if ambient_context:
            try:
                ambient_scent_ids = _get_ambient_scent_ids()
                scent = _parse_int(body.get("scent"), 0)
                if scent not in ambient_scent_ids and feedback_data:
                    feedback_parts = feedback_data.split("_", 1)
                    if feedback_parts and feedback_parts[0].isdigit():
                        scent = int(feedback_parts[0])
                if scent not in ambient_scent_ids:
                    scent = int(config.AMBIENT_DEFAULT_SCENT)

                raw_value = body.get("value", 1)
                try:
                    val = int(raw_value)
                except Exception:
                    normalized_value = str(raw_value).strip().lower()
                    val = 1 if normalized_value in ["1", "good", "like", "true"] else -1

                weight_val = 1 if val == 1 else -1
                db_utils.seed_ambient_defaults()
                db_utils.save_ambient_feedback(ambient_context, scent, weight_val)
                return {
                    "statusCode": 200,
                    "headers": {"Content-Type": "application/json"},
                    "body": json.dumps({
                        "message": "Ambient feedback saved",
                        "spray": 0,
                        "cmd": 0,
                        "context": f"Ambient_{ambient_context}",
                        "ambient_context": ambient_context,
                        "value": weight_val
                    }, ensure_ascii=False)
                }
            except Exception as e:
                return {"statusCode": 500, "body": str(e)}

        try:
            val = body.get("value", 1) 
            is_like = (val == 1)

            # 앱은 "향기번호_상황" 문자열을 'data' 키로 보냄
            data_str = body.get("data", "1_Unknown")
            parts = data_str.split("_", 1)

            scent = int(parts[0]) if parts[0].isdigit() else 1
            ctx = parts[1] if len(parts) > 1 else "Unknown"
            
            # ★ [수정] 한국어 4등분 시간대로 검사 및 강제 생성
            if "새벽" not in ctx and "오전" not in ctx and "오후" not in ctx and "밤" not in ctx:
                now_kst = datetime.now(timezone(timedelta(hours=9)))
                h = now_kst.hour
                
                if 0 <= h < 6:
                    t_zone = "새벽"
                elif 6 <= h < 12:
                    t_zone = "오전"
                elif 12 <= h < 18:
                    t_zone = "오후"
                else:
                    t_zone = "밤"
                
                # 날씨 정보만 있는 경우 시간대 결합 (예: Weather_Sunny -> Weather_Sunny_오후)
                if ctx.startswith("Weather_"):
                    ctx = f"{ctx}_{t_zone}"

            # ★ [2] 가중치 업데이트: 좋아요면 +1, 싫어요면 -1
            weight_val = 1 if is_like else -1
            db_utils.save_feedback(device_id, ctx, scent, weight_val)

            # (이하 기존 싫어요/좋아요 처리 로직 동일...)

            # [3] 싫어요(False)일 때 로직
            if not is_like:
                # 쿨타임 강제 초기화 (즉시 다른 향 분사 가능하게)
                db_utils.state_table.update_item(
                    Key={'deviceId': device_id},
                    UpdateExpression="set last_spray_time = :t",
                    ExpressionAttributeValues={':t': "2000-01-01T00:00:00"}
                )
                
                # 현재 싫은 향 제외하고 랜덤 선택
                candidates = [s for s in [1, 2, 3, 4] if s != scent]
                new_scent = random.choice(candidates)
                
                # ★ [4] 새로 추천된 향기에도 가중치 +1 부여 (사용자 유도)
                db_utils.save_feedback(device_id, ctx, new_scent, 1)
                db_utils.manage_mailbox(device_id, new_scent)
                
                return {
                    "statusCode": 200,
                    "headers": {"Content-Type": "application/json"},
                    "body": json.dumps({
                        "message": f"싫어요 반영! {new_scent}번 향으로 우회 학습",
                        "spray": new_scent,
                        "context": ctx # 어떤 상황에서 저장됐는지 앱에 피드백
                    }, ensure_ascii=False)
                }

            # 좋아요인 경우
            return {
                "statusCode": 200,
                "headers": {"Content-Type": "application/json"},
                "body": json.dumps({
                    "message": "좋아요! 사용자 선호도 학습 완료", 
                    "spray": scent,
                    "context": ctx
                }, ensure_ascii=False)
            }

        except Exception as e:
             return {"statusCode": 500, "body": str(e)}
             
    elif action == "TIMER_START":
        try:
            spray_code = int(body.get("spray", 1))
            run_minutes = int(body.get("run_minutes", 1))
            
            # 기기에 시작 명령 전달
            db_utils.manage_mailbox(device_id, spray_code)
            
            # 서버 DB에 '몇 분 뒤에 꺼야 하는지' 기록
            now_kst = datetime.now(timezone(timedelta(hours=9)))
            stop_time = now_kst + timedelta(minutes=run_minutes)
            db_utils.state_table.update_item(
                Key={'deviceId': device_id},
                UpdateExpression="set auto_stop_time = :t",
                ExpressionAttributeValues={':t': stop_time.isoformat()}
            )
            return {"statusCode": 200, "headers": {"Content-Type": "application/json"}, "body": json.dumps({"spray": spray_code, "message": f"{run_minutes}분 작동 후 서버가 정지합니다.", "result_text": "OK"}, ensure_ascii=False)}
        except Exception as e: 
            return {"statusCode": 500, "body": str(e)}

    if action == "POLL":
        current_w = normalized_weights[0]
        logger.info(f"[POLL_DATA] 수신된 전체 무게 배열: {body.get('weights')} | 정규화 배열: {normalized_weights}")

        try:
            db_utils.state_table.update_item(
                Key={'deviceId': device_id},
                UpdateExpression="set weight_g = :wg, weights = :w",
                ExpressionAttributeValues={
                    ':wg': Decimal(str(current_w)),
                    ':w': _to_decimal_list(normalized_weights)
                }
            )
        except Exception as e:
            logger.error(f"무게 DB 업데이트 실패: {e}")

        state = db_utils.get_device_state(device_id) or {}
        auto_stop_str = state.get('auto_stop_time', "")
        if auto_stop_str:
            try:
                auto_stop_time = datetime.fromisoformat(auto_stop_str)
                now_kst = datetime.now(timezone(timedelta(hours=9)))
                if now_kst >= auto_stop_time:
                    # 약속된 시간이 지났으면 우체통에 정지명령(0)을 넣고 타이머 삭제
                    db_utils.manage_mailbox(device_id, 90)
                    db_utils.state_table.update_item(Key={'deviceId': device_id}, UpdateExpression="remove auto_stop_time")
            except: pass

        # ★ [수정] 앱(email 포함)에서 온 POLL이면 Peek(지우지 않기) 모드로 작동
        is_app_request = True if body.get("email") else False
        spray_code, target_region, duration = db_utils.manage_mailbox(device_id, is_peek=is_app_request)
        
        music_code = db_utils.get_music_track(device_id, spray_code) if spray_code > 0 else 0
        
        state = db_utils.get_device_state(device_id) or {}
        intensity = int(state.get('intensity', 2)) 

        return {
            "statusCode": 200,
            "headers": {"Content-Type": "application/json"},
            "body": json.dumps({
                "spray": int(spray_code),
                "music": int(music_code),
                "duration": int(duration),
                "target_region": target_region,
                "intensity": intensity,
                "weights": normalized_weights,
                "result_text": "명령없음" if spray_code in [0, -1] else f"명령:{spray_code}"
            }, ensure_ascii=False)
        }
        
    # [ACTION] MENU_STOP
    elif action in ["MENU_STOP", "STOP_ALL"] or mode == "menu":
        db_utils.manage_mailbox(device_id, 90)
        try: db_utils.state_table.update_item(Key={'deviceId': device_id}, UpdateExpression="remove auto_stop_time")
        except: pass
        return {
            "statusCode": 200,
            "headers": {"Content-Type": "application/json"},
            "body": json.dumps({"spray": 90, "message": "정지 명령", "result_text": "정지"}, ensure_ascii=False)
        }

    # [ACTION] MANUAL
    elif action == "MANUAL":
        try:
            spray_code = int(body.get("spray", 1))
            region_req = body.get("region", "")
            duration = int(body.get("duration", 3)) 

            # 하드웨어가 POLL 시 가져갈 수 있도록 우체통에 저장
            db_utils.manage_mailbox(device_id, spray_code, region_req, duration)

            try: db_utils.state_table.update_item(Key={'deviceId': device_id}, UpdateExpression="remove auto_stop_time")
            except: pass
            
            music_code = spray_code
            if spray_code in [1, 2, 3, 4]:
                music_code = db_utils.get_music_track(device_id, spray_code)
                
            result_text = f"수동 명령 저장: {spray_code}번 (DeviceId: {device_id})"
            
            state = db_utils.get_device_state(device_id) or {}
            intensity = int(state.get('intensity', 2))
            
            return {
                "statusCode": 200,
                "headers": {"Content-Type": "application/json"},
                "body": json.dumps({
                    "result": "SUCCESS",
                    "spray": spray_code,
                    "duration": duration, 
                    "intensity": intensity,  
                    "result_text": result_text,
                    "message": result_text
                }, ensure_ascii=False)
            }
        except Exception as e:
            return {"statusCode": 500, "body": json.dumps({"result": "FAIL", "message": str(e)}, ensure_ascii=False)}

    # [ACTION] START (이전 버전 호환성 유지)
    elif action == "START":
        try:
            start_code = int(body.get("spray", 1))
            duration = int(body.get("duration", 3))
            region_req = body.get("region", "Manual")
            db_utils.manage_mailbox(device_id, start_code, region_req, duration)
            return {
                "statusCode": 200,
                "headers": {"Content-Type": "application/json"},
                "body": json.dumps({
                    "result": "SUCCESS", 
                    "spray": start_code, 
                    "message": f"START 명령 수신 (ID: {device_id})",
                    "duration": duration
                }, ensure_ascii=False)
            }
        except Exception as e:
            return {"statusCode": 500, "body": str(e)}

    elif mode == "ambient":
        try:
            now_kst = _get_kst_now()
            db_level_raw = body.get("db_level", body.get("noise_level", body.get("noise", 0)))
            context_key, time_slot, noise_bucket, normalized_db = _build_ambient_context(db_level_raw, now_kst)

            db_utils.seed_ambient_defaults()
            # 1. 기기 정보를 넘겨주어 장착된 향기 중 가장 랭킹이 높은 kind 추출
            best_kind, ambient_scores = db_utils.get_ambient_recommendation(context_key, device_id)
            # 2. 해당 kind가 장착된 하드웨어 spray 슬롯 번호(1~4)로 변환
            spray_code = db_utils.get_spray_from_kind(device_id, best_kind)
            if not spray_code:
                spray_code = 1 # 안전 장치
            duration = _parse_int(
                body.get("dur", body.get("duration", config.AMBIENT_DURATION_SECONDS)),
                config.AMBIENT_DURATION_SECONDS
            )

            state = db_utils.get_device_state(device_id) or {}
            last_time_str = state.get('last_spray_time', "2000-01-01T00:00:00")
            current_capacity = float(state.get('current_capacity', config.MAX_CAPACITY))

            state_weights = state.get('weights', normalized_weights)
            preserved_weights = []
            for weight in state_weights if isinstance(state_weights, list) else normalized_weights:
                try:
                    preserved_weights.append(float(weight))
                except Exception:
                    preserved_weights.append(0.0)
            while len(preserved_weights) < 4:
                preserved_weights.append(0.0)
            preserved_weights = preserved_weights[:4]

            is_blocked = False
            if spray_code > 0:
                try:
                    last_time = datetime.fromisoformat(last_time_str)
                    if (now_kst - last_time).total_seconds() < (config.COOLDOWN_MINUTES * 60):
                        is_blocked = True
                except Exception:
                    pass

            result_text = f"Ambient {context_key} -> scent {spray_code}"

            if is_blocked:
                return {
                    "statusCode": 200,
                    "headers": {"Content-Type": "application/json"},
                    "body": json.dumps(
                        _build_ambient_response(
                            0,
                            duration,
                            context_key,
                            normalized_db,
                            "Ambient cooldown active",
                            ambient_scores
                        ),
                        ensure_ascii=False
                    )
                }

            new_capacity = current_capacity
            if spray_code > 0:
                usage = duration * config.CONSUMPTION_PER_SEC
                new_capacity = round(max(0.0, current_capacity - usage), 2)
                db_utils.update_device_state(device_id, now_kst.isoformat(), new_capacity, spray_code, preserved_weights)

            try:
                def safe_dec(v): return Decimal(str(v)) if v is not None else Decimal("0")

                db_utils.log_table.put_item(Item={
                    "deviceId": device_id,
                    "timestamp": now_kst.isoformat(),
                    "mode": "Ambient_Mode",
                    "result_text": result_text,
                    "spray_code": int(spray_code),
                    "duration": int(duration),
                    "region": context_key,
                    "weight_g": safe_dec(preserved_weights[0]),
                    "weights": [safe_dec(weight) for weight in preserved_weights],
                    "temp": safe_dec(0),
                    "humid": 0,
                    "feedback": 1,
                    "db_level": int(normalized_db)
                })
            except Exception as e:
                logger.warning(f"Ambient log save failed: {e}")

            response_payload = _build_ambient_response(
                spray_code,
                duration,
                context_key,
                normalized_db,
                result_text,
                ambient_scores
            )
            response_payload["time_slot"] = time_slot
            response_payload["noise_bucket"] = noise_bucket
            response_payload["remaining_capacity"] = new_capacity

            return {
                "statusCode": 200,
                "headers": {"Content-Type": "application/json"},
                "body": json.dumps(response_payload, ensure_ascii=False)
            }
        except Exception as e:
            logger.error(f"[AMBIENT_MODE_CRASH] {e}")
            return {
                "statusCode": 500,
                "headers": {"Content-Type": "application/json"},
                "body": json.dumps({
                    "cmd": 0,
                    "dur": int(config.AMBIENT_DURATION_SECONDS),
                    "music": 0,
                    "spray": 0,
                    "duration": int(config.AMBIENT_DURATION_SECONDS),
                    "message": f"Ambient mode error: {str(e)}",
                    "mode": "Ambient_Mode"
                }, ensure_ascii=False)
            }

    # ======================================================================
    # [기존 로직] 날씨 모드, 감성 모드
    # ======================================================================
    weight_g = normalized_weights[0]
    
    logger.info(f"[WEIGHT_SYNC] 정규화된 무게 배열: {normalized_weights} | 대표 무게: {weight_g}g")

    spray_code = 0
    result_text = ""
    logic_name = ""
    temp = "0"
    humidity = "0"
    duration = 3
    context_key = "Unknown"
    weather_text = ""

    # [A] 감성 모드
    if mode == "emotion":
        user_emo = body.get("user_emotion", "평범")
        context_key = f"Emotion_{user_emo}"
        
        # (기존 코드 삭제) gpt_spray, gpt_reason = api_utils.ask_gpt_recommendation(...)
        
        # 1. 변경된 Gemini 함수 호출 (일기 내용과 과거 기록 전달)
        # 당장 과거 기록 변수가 없다면 빈 문자열("")을 넘겨줍니다.
        gemini_kind_str, ai_reason = api_utils.ask_gemini_recommendation(diary_text=user_emo, user_history_text="")
        
        # 2. 반환받은 향기(kind) 문자열(예: "14" 또는 "5")을 실제 물리적 spray 번호로 매핑
        try:
            kind_code = int(gemini_kind_str) if gemini_kind_str != "0" else 0
        except Exception:
            kind_code = 0

        if kind_code > 0:
            mapped_spray = db_utils.get_spray_from_kind(device_id, kind_code)
            if not mapped_spray:
                # 추천받은 향기가 기기에 하나도 안 꽂혀있다면 기본값인 1번 펌프로 폴백
                mapped_spray = 1
                ai_reason += " (알림: 추천 향기가 기기에 없어 기본 1번 칸 향기로 대체 분사됩니다.)"
                
            spray_code, result_text, logic_name = mapped_spray, ai_reason, "AI_Gemini_Emotion"
            duration = 3
        else:
            spray_code, result_text, logic_name, duration = logic_emotion_mode(user_emo)
    # [B] 날씨 모드
    else:
        try: # ★ 날씨 로직 전체를 try로 감싸기 시작
            if region == "테스트맑음":
                spray_code, result_text, logic_name, duration = 1, "테스트 맑음 실행", "Test_Weather", 3
                context_key = "Weather_Sunny"
            elif region == "테스트흐림":
                spray_code, result_text, logic_name, duration = 2, "테스트 흐림 실행", "Test_Weather", 3
                context_key = "Weather_Cloudy"
            elif region == "테스트비":
                spray_code, result_text, logic_name, duration = 3, "테스트 비 실행", "Test_Weather", 3
                context_key = "Weather_Rain"
            elif region == "테스트눈":
                spray_code, result_text, logic_name, duration = 4, "테스트 눈 실행", "Test_Weather", 3
                context_key = "Weather_Snow"
            else:
                if not region: region = "서울"
