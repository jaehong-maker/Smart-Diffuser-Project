                    if 6 <= current_hour < 12:
                        time_zone = "Morning"
                    elif 12 <= current_hour < 18:
                        time_zone = "Afternoon"
                    else:
                        time_zone = "Night"
                    
                    w_key = "Sunny"
                    if w_res and any(x in w_res for x in ["비", "강수"]): w_key = "Rain"
                    elif w_res and "눈" in w_res: w_key = "Snow"
