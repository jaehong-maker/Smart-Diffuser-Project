def lambda_handler(event, context):
    logger.info("============== [REQUEST START] ==============")

        # 0. 원본 요청 로그
    try:
        logger.info(f"[EVENT] {json.dumps(event, ensure_ascii=False)}")
    except Exception as e:
        logger.warning(f"[EVENT_LOG_FAIL] {e}")

    raw_body = event.get("body", "")
    logger.info(f"[RAW_BODY] {raw_body}")

    try:
        parsed_preview = json.loads(raw_body) if raw_body else {}
        logger.info(f"[PARSED_BODY] {json.dumps(parsed_preview, ensure_ascii=False)}")
        logger.info(f"[BODY_KEYS] {list(parsed_preview.keys())}")
        logger.info(
            f"[BODY_VALUES] action={parsed_preview.get('action')}, "
            f"mode={parsed_preview.get('mode')}, "
            f"region={parsed_preview.get('region')}, "
            f"w1={parsed_preview.get('w1')}, "
            f"w2={parsed_preview.get('w2')}, "
            f"w3={parsed_preview.get('w3')}, "
            f"w4={parsed_preview.get('w4')}, "
            f"weights={parsed_preview.get('weights')}"
        )
    except Exception as e:
        logger.warning(f"[BODY_PARSE_FAIL] {e}")

    # ★ [핵심] 무조건 이 ID 하나만 사용 (연결 문제 해결용)
    # 앱에서 다른 ID를 보내도 무시하고 이걸로 강제 통일합니다.
    device_id = "ESP32_Test" 

    # 1. 헤더 분석
    headers = event.get("headers") or {}
    content_type = _get_header(headers, "content-type")
    
    # ------------------------------------------------------
    # [A] 음성 모드 처리
    # ------------------------------------------------------
    if "audio/wav" in str(content_type).lower():
        try:
            bucket = os.environ.get("AUDIO_BUCKET", "")
            if not bucket: return {"statusCode": 500, "body": json.dumps({"message": "Server Error: AUDIO_BUCKET not set"})}

            raw_body = event.get("body", "") or ""
            is_b64 = bool(event.get("isBase64Encoded", False))
            wav_bytes = base64.b64decode(raw_body) if is_b64 else raw_body.encode("latin1")
            
            # S3 업로드 (강제 통일된 device_id 사용)
            key = f"voice/{device_id}/{datetime.now(timezone(timedelta(hours=9))).strftime('%Y%m%d_%H%M%S')}_{uuid.uuid4().hex[:8]}.wav"
            s3.put_object(Bucket=bucket, Key=key, Body=wav_bytes, ContentType="audio/wav")
            
            # STT 실행
            transcript = _transcribe_wav_from_s3(bucket, key, language_code=os.environ.get("VOICE_LANG", "ko-KR"))
            
            # 실패 원인별 메시지 처리
            if transcript in ["SILENCE", "FAIL", "ERROR", "TIMEOUT", ""]:
                msg_map = {
                    "SILENCE": "목소리가 들리지 않습니다(묵음).",
                    "FAIL": "STT 변환 실패(AWS 오류).",
                    "ERROR": "STT 시스템 에러.",
                    "TIMEOUT": "STT 시간 초과(너무 오래 걸림).",
                    "": "알 수 없는 오류."
                }
                msg = msg_map.get(transcript, "인식 실패")
                return {"statusCode": 200, "body": json.dumps({"spray": 0, "message": msg}, ensure_ascii=False)}

            spray_code, duration, result_text = _voice_to_spray(transcript)

            # 쿨타임 체크
            state = get_device_state(device_id) or {}
            last_time_str = state.get('last_spray_time', "2000-01-01T00:00:00")
            now = datetime.now(timezone(timedelta(hours=9)))
            try:
                last_time = datetime.fromisoformat(last_time_str)
                if (now - last_time).total_seconds() < (COOLDOWN_MINUTES * 60):
                    return {
                        "statusCode": 200,
                        "body": json.dumps({"spray": 0, "message": "쿨타임 중이라 분사할 수 없습니다.", "mode": "CoolDown"}, ensure_ascii=False)
                    }
            except: pass

            # 명령 저장 & 기기 상태 업데이트
            if spray_code > 0:
                manage_mailbox(device_id, spray_code)
                current_cap = float(state.get('current_capacity', MAX_CAPACITY))
                new_cap = round(max(0.0, current_cap - (duration * CONSUMPTION_PER_SEC)), 2)
                update_device_state(device_id, now.isoformat(), new_cap, spray_code, 0)

            return {
                "statusCode": 200,
                "headers": {"Content-Type": "application/json"},
                "body": json.dumps({
                    "spray": int(spray_code),
                    "message": f"음성 인식 성공: {result_text}",
                    "transcript": transcript,
                    "duration": duration
                }, ensure_ascii=False)
            }

        except Exception as e:
            logger.error(f"[VOICE_FATAL] {e}")
            return {"statusCode": 200, "body": json.dumps({"spray": 0, "message": f"음성 처리 에러: {str(e)}"}, ensure_ascii=False)}

    # ------------------------------------------------------
    # [B] 일반 JSON 모드 처리
    # ------------------------------------------------------
    raw_body = event.get("body", {})
    try:
        if isinstance(raw_body, str):
            body = json.loads(raw_body) if raw_body else {}
        elif isinstance(raw_body, dict):
            body = raw_body
        else:
            body = {}
    except Exception as e:
        logger.warning(f"[JSON_PARSE_ERROR] {e}")
        body = {}

    # (여기서 device_id를 다시 뽑지 않고 위에서 정한 'ESP32_Test'를 그대로 씁니다)

    mode = body.get("mode", "weather")
    region = body.get("region", "")
    action = body.get("action", "")

    # [ACTION] SIGNUP: 회원가입 (Partition Key: email)
    if action == "SIGNUP":
        try:
            u_email = body.get("email")
            u_name = body.get("name", "사용자")
            u_region = body.get("region", "서울") 
            u_scent = body.get("scent", 1)       

            if not u_email:
                return {"statusCode": 200, "body": json.dumps({"message": "이메일은 필수입니다.", "result": "FAIL"}, ensure_ascii=False)}

            user_table.put_item(Item={
                'email': u_email, # ★ 파티션 키
                'name': u_name,
                'region': u_region,
                'prefScent': int(u_scent),
                'createdAt': datetime.now(timezone(timedelta(hours=9))).isoformat()
            })
            return {"statusCode": 200, "body": json.dumps({"message": f"{u_name}님, 가입 성공!", "result": "SUCCESS"}, ensure_ascii=False)}
        except Exception as e:
            return {"statusCode": 500, "body": str(e)}

    # [ACTION] LOGIN: 로그인 및 정보 불러오기
    elif action == "LOGIN":
        try:
            u_email = body.get("email")
            res = user_table.get_item(Key={'email': u_email})
            
            if 'Item' in res:
                user_info = res['Item']
                return {
                    "statusCode": 200,
                    "body": json.dumps({
                        "message": f"{user_info.get('name')}님 환영합니다!",
                        "result": "SUCCESS",
                        "region": user_info.get('region', '서울'),
                        "scent": int(user_info.get('prefScent', 1))
                    }, ensure_ascii=False)
                }
            else:
                return {"statusCode": 200, "body": json.dumps({"message": "가입되지 않은 이메일입니다.", "result": "FAIL"}, ensure_ascii=False)}
        except Exception as e:
            return {"statusCode": 500, "body": str(e)}
    if action == "SAVE_MUSIC":
        try:
            # ★ 핵심: 앱이 어떤 필드명으로 보내든 다 체크하도록 수정
            music_data = body.get("region") or body.get("context") or body.get("music") or body.get("tracks")
            
            if music_data and "_" in str(music_data):
                state_table.update_item(
                    Key={'deviceId': device_id},
                    UpdateExpression="set music_tracks = :m",
                    ExpressionAttributeValues={':m': str(music_data)}
                )
                logger.info(f"[SAVE_MUSIC] 저장 완료: {music_data}")
                msg = f"음악 설정({music_data}) 저장 완료"
            else:
                msg = "잘못된 데이터 포맷 (예: 1_2_3_4)"

            return {
                "statusCode": 200,
                "headers": {"Content-Type": "application/json"},
                "body": json.dumps({"spray": 0, "message": msg, "result_text": "OK"}, ensure_ascii=False)
            }
        except Exception as e:
            logger.error(f"SAVE_MUSIC Error: {e}")
            return {"statusCode": 500, "body": str(e)}
# [ACTION] FEEDBACK
    if action == "FEEDBACK":
        try:
            rating = body.get("rating", "good")
            is_like = (rating == 1) if isinstance(rating, int) else (rating == "good")
            
            # 1. 어떤 향기를 싫어하는지 알아내기
            scent = body.get("spray") or body.get("sprayNum")
            if not scent:
                state = get_device_state(device_id) or {}
                scent = int(state.get('last_spray_code', 1))
            else:
                scent = int(scent)

            # 2. 검색어 통일 (앱은 "3_Weather_안양" 등으로 보냄)
            raw_ctx = body.get("context", "Unknown")
            
            if "_" in raw_ctx and raw_ctx[0].isdigit():
                parts = raw_ctx.split("_", 1)  
                scent = int(parts[0])          
                ctx = parts[1]                 
            else:
                ctx = raw_ctx

            if ctx.startswith("Weather_") and not any(k in ctx for k in ["Sunny", "Rain", "Snow", "Cloudy"]):
                region_name = ctx.replace("Weather_", "")
                if region_name in REGION_COORDS and "SERVICE_KEY" in os.environ:
                    nx, ny = REGION_COORDS[region_name]["nx"], REGION_COORDS[region_name]["ny"]
                    bd, bt = get_kma_time()
                    params = {"serviceKey": os.environ["SERVICE_KEY"], "pageNo": "1", "numOfRows": "10", "dataType": "XML", "base_date": bd, "base_time": bt, "nx": nx, "ny": ny}
                    _, w_res, _ = forecast(params)
                    w_key = "Sunny"
                    if "비" in w_res or "강수" in w_res: w_key = "Rain"
                    elif "눈" in w_res: w_key = "Snow"
                    elif "흐림" in w_res or "구름" in w_res: w_key = "Cloudy"
                    ctx = f"Weather_{w_key}"

            # 3. DB에 취향 저장
            save_feedback(device_id, ctx, scent, is_like)

            # ★ 4. 핵심 해결책: DB 지연 문제 완벽 회피 & 무조건 새 향 강제 추천
            if not is_like:
                # 기기 쿨타임 강제 초기화
                state_table.update_item(
                    Key={'deviceId': device_id},
                    UpdateExpression="set last_spray_time = :t",
                    ExpressionAttributeValues={':t': "2000-01-01T00:00:00"}
                )
                
                # DB 읽기를 기다리지 않고, 방금 뿜은 향기(scent)를 리스트에서 빼고 무조건 남은 것 중 하나를 고릅니다!
                candidates = [s for s in [1, 2, 3, 4] if s != scent]
                new_scent = random.choice(candidates)
                
                # 기기 우체통에 새 향 예약
                manage_mailbox(device_id, new_scent)
                
                return {
                    "statusCode": 200,
                    "headers": {"Content-Type": "application/json"},
                    "body": json.dumps({
                        "message": f"피드백 완료. {new_scent}번 향으로 변경!",
                        "spray": new_scent,
                        "sprayNum": new_scent  # 안드로이드가 혹시 sprayNum을 찾을까봐 같이 보냄
                    }, ensure_ascii=False)
                }

            # '좋아요'일 때는 기존 향 유지
            return {
                "statusCode": 200,
                "headers": {"Content-Type": "application/json"},
                "body": json.dumps({"message": "피드백 반영 완료", "spray": scent, "sprayNum": scent}, ensure_ascii=False)
            }
        except Exception as e:
             return {"statusCode": 500, "body": str(e)}
             
        
    if action == "POLL":
        # ESP32 pollServer()에서 보내는 weights 배열 추출 
        weights = body.get("weights")
        
        # 배열 형식이면 첫 번째 값(W1)을 사용하고, 아니면 개별 변수 체크 
        current_w = 0
        if isinstance(weights, list) and len(weights) > 0:
            current_w = weights[0]
        else:
            current_w = body.get("w1", body.get("w4", 0))

        # CloudWatch 로그 기록 [cite: 181, 139]
        logger.info(f"[POLL_DATA] 수신된 전체 무게 배열: {weights} | 저장할 무게: {current_w}g")

        # DynamoDB(state_table)의 last_weight_g 필드 실시간 갱신 [cite: 111, 270]
        try:
            state_table.update_item(
                Key={'deviceId': device_id},
                UpdateExpression="set last_weight_g = :w",
                ExpressionAttributeValues={':w': Decimal(str(current_w))}
            )
        except Exception as e:
            logger.error(f"무게 DB 업데이트 실패: {e}")

        # 예약된 명령 및 음악 트랙 확인
        spray_code, target_region = manage_mailbox(device_id)
        music_code = get_music_track(device_id, spray_code) if spray_code > 0 else 0

        return {
            "statusCode": 200,
            "headers": {"Content-Type": "application/json"},
            "body": json.dumps({
                "spray": int(spray_code),
                "music": int(music_code),
                "target_region": target_region,
                "result_text": "명령없음" if spray_code == 0 else f"명령:{spray_code}"
            }, ensure_ascii=False)
        }
    # [ACTION] MENU_STOP (메뉴 복귀 시 기기 정지)
    elif action in ["MENU_STOP", "STOP_ALL"] or mode == "menu":
        manage_mailbox(device_id, 90)
        return {
            "statusCode": 200,
            "headers": {"Content-Type": "application/json"},
            "body": json.dumps({"spray": 90, "message": "정지 명령", "result_text": "정지"}, ensure_ascii=False)
        }

    # [ACTION] MANUAL (앱이 수동 분사 명령)
    elif action == "MANUAL":
        try:
            spray_code = int(body.get("spray", body.get("sprayNum", 1))) 
            region_req = body.get("region", "")
            manage_mailbox(device_id, spray_code, region_req)
            
            # ★ 핵심: DB에 저장된 진짜 음악 번호를 꺼내서 앱 화면에 보여주기
            music_code = spray_code
            if spray_code in [1, 2, 3, 4]:
                music_code = get_music_track(device_id, spray_code)
                
            result_text = f"명령: {spray_code}번 / 서버음악: {music_code}번"
        except Exception as e:
            spray_code = 0
            result_text = f"명령 오류: {str(e)}"

        return {
            "statusCode": 200,
            "headers": {"Content-Type": "application/json"},
            "body": json.dumps({
                "spray": spray_code,
                "result_text": result_text,
                "message": result_text
            }, ensure_ascii=False)
        }
    # ======================================================================
    # [기존 로직] 날씨 모드, 감성 모드
    # ======================================================================
    received_weights = body.get("weights")
    received_w4 = body.get("w4", 0)

    if isinstance(received_weights, list) and len(received_weights) > 0:
        weight_g = received_weights[0]
    else:
        weight_g = received_w4

    if weight_g is None: weight_g = 0
    
    # 로그 확인용 [cite: 270]
    logger.info(f"[WEIGHT_SYNC] 최종 결정된 무게 값: {weight_g}g")

    spray_code = 0
    result_text = ""
    logic_name = ""
    temp = "0"
    humidity = "0"
    duration = 3
    context_key = "Unknown"
    weather_text = ""

    # [A] 감성 모드
    if mode == "emotion":
        user_emo = body.get("user_emotion", "평범")
        context_key = f"Emotion_{user_emo}"
        gpt_spray, gpt_reason = ask_gpt_recommendation(weather="실내", emotion=user_emo)
        if gpt_spray > 0:
            spray_code, result_text, logic_name = gpt_spray, gpt_reason, "AI_GPT_Emotion"
        else:
            spray_code, result_text, logic_name, duration = logic_emotion_mode(user_emo)
            
    # [B] 날씨 모드
    else:
        # ==========================================
        # 🔥 [추가] 앱/기기 테스트용 키워드 강제 처리
        # ==========================================
        if region == "테스트맑음":
            spray_code, result_text, logic_name, duration = 1, "테스트 맑음 실행", "Test_Weather", 3
            context_key = "Weather_Sunny"
        elif region == "테스트흐림":
            spray_code, result_text, logic_name, duration = 2, "테스트 흐림 실행", "Test_Weather", 3
            context_key = "Weather_Cloudy"
        elif region == "테스트비":
            spray_code, result_text, logic_name, duration = 3, "테스트 비 실행", "Test_Weather", 3
            context_key = "Weather_Rain"
        elif region == "테스트눈":
            spray_code, result_text, logic_name, duration = 4, "테스트 눈 실행", "Test_Weather", 3
            context_key = "Weather_Snow"
        
        # ==========================================
        # 원래 기상청 API 조회 로직 (테스트 단어가 아닐 때만 실행)
        # ==========================================
        else:
            if not region: region = "서울"
            if region not in REGION_COORDS: region = "서울"
            nx, ny = REGION_COORDS[region]["nx"], REGION_COORDS[region]["ny"]
            
            if "SERVICE_KEY" in os.environ:
                bd, bt = get_kma_time()
                params = {
                    "serviceKey": os.environ["SERVICE_KEY"],
                    "pageNo": "1", "numOfRows": "10", "dataType": "XML",
                    "base_date": bd, "base_time": bt, "nx": nx, "ny": ny
                }
                temp, w_res, humidity = forecast(params)
                weather_text = w_res
                w_key = "Sunny"
                if "비" in w_res or "강수" in w_res: w_key = "Rain"
                elif "눈" in w_res: w_key = "Snow"
                elif "흐림" in w_res or "구름" in w_res: w_key = "Cloudy"
                context_key = f"Weather_{w_key}"
                
                gpt_spray, gpt_reason = ask_gpt_recommendation(weather=w_res, emotion="날씨에 맞김")
                if gpt_spray > 0:
                    spray_code, result_text, logic_name = gpt_spray, gpt_reason, "AI_GPT_Weather"
                else:
                    spray_code, result_text, logic_name, duration = logic_weather_mode(w_res, humidity)
            else:
                spray_code, result_text = 1, "API키없음"
    # [싫어요 목록 확인 및 교체]
    if spray_code > 0:
        final_scent, ai_msg = get_personalized_scent(device_id, context_key, spray_code)
        if final_scent != spray_code:
            logger.info(f"[AI Change] {spray_code} -> {final_scent} ({ai_msg})")
            result_text += f" {ai_msg}"
            spray_code = final_scent

# 상태 및 쿨타임 확인
    state = get_device_state(device_id) or {}
    last_time_str = state.get('last_spray_time', "2000-01-01T00:00:00")
    current_capacity = float(state.get('current_capacity', MAX_CAPACITY))

    now = datetime.now(timezone(timedelta(hours=9)))
    is_blocked = False
    log_msg = ""

    # ★ 앱에서 모드를 새로 시작할 때(START)는 쿨타임을 무시하도록 수정
    if spray_code > 0 and action != "START":
        try:
            last_time = datetime.fromisoformat(last_time_str)
            if (now - last_time).total_seconds() < (COOLDOWN_MINUTES * 60):
                is_blocked = True
                remaining_sec = int((COOLDOWN_MINUTES * 60) - (now - last_time).total_seconds())
                log_msg = f"쿨타임 중: {remaining_sec}초 남음"
        except: pass

    # 차단 시 응답 (WAIT 현상 해결)
    if is_blocked:
        return {
            "statusCode": 200,
            "headers": {"Content-Type": "application/json"},
            "body": json.dumps({
                "spray": 0,
                "result_text": result_text, 
                "message": log_msg,
                "mode": "CoolDown"
            }, ensure_ascii=False)
        }

    # 최종 실행 및 로그 저장
    new_capacity = current_capacity
    if spray_code > 0:
        if action == "START":
            # 1. 앱에서 모드 시작 버튼을 눌렀을 때: 기기 우체통에 '30(날씨 모드)' 번호만 넣음.
            # 쿨타임(last_spray_time)은 여기서 갱신하지 않습니다! (기기가 곧바로 다시 물어볼 것이기 때문)
            start_code = int(body.get("spray", 30))
            manage_mailbox(device_id, start_code)
        else:
            # 2. 기기(ESP32)가 직접 람다에 날씨를 물어보러 왔을 때 (action이 없음)
            # 우체통에 중복으로 넣지 않고, 쿨타임을 이 시점에 확실하게 갱신합니다.
            usage = duration * CONSUMPTION_PER_SEC
            new_capacity = round(max(0.0, current_capacity - usage), 2)
            update_device_state(device_id, now.isoformat(), new_capacity, spray_code, weight_g)

    try:
        def safe_int(v): return int(float(v)) if v else 0
        def safe_dec(v): return Decimal(str(v)) if v else Decimal("0")

        log_table.put_item(Item={
            "deviceId": device_id,
            "timestamp": now.isoformat(),
            "mode": logic_name,
            "result_text": result_text,
            "spray_code": int(spray_code),
            "duration": int(duration),
            "region": region if mode == "weather" else "Emotion",
            "weight_g": safe_dec(weight_g),
            "temp": safe_dec(temp),
            "humid": safe_int(humidity),
            "feedback": 1
        })
    except Exception as e:
        logger.warning(f"Log save failed: {e}")

    music_code = spray_code
    if spray_code in [1, 2, 3, 4]:
        music_code = get_music_track(device_id, spray_code)
    # 최종 응답
    return {
        "statusCode": 200,
        "headers": {"Content-Type": "application/json"},
        "body": json.dumps({
            "weather": weather_text,
            "spray": spray_code,
            "music": music_code,
            "result_text": result_text,
            "duration": duration,
            "temp": temp,
            "humidity": humidity,
            "remaining_capacity": new_capacity,
            "message": f"분석 성공! ({result_text})",
            "mode": logic_name
        }, ensure_ascii=False)
    }
