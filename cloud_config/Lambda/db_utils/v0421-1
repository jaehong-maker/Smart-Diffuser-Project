    try:
        score_col = f"scent_{scent_code}_score"
        
        # ★ 캡처 화면(image_bb135d)에 적힌 정확한 키 이름으로 매칭
        # 이름 자체가 'deviceId(String)'와 'context(String)'인 상태임
