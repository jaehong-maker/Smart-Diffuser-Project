logger = logging.getLogger()

# DynamoDB
dynamodb = boto3.resource('dynamodb')
log_table = dynamodb.Table('DiffuserLog')
state_table = dynamodb.Table('DiffuserState')
pref_table = dynamodb.Table('DiffuserPref') 
user_table = dynamodb.Table('DiffuserUsers')
auth_table = dynamodb.Table('DiffuserAuth')
diary_table = dynamodb.Table('UserDiaries')

def get_music_track(device_id, spray_code):
    try:
        res = state_table.get_item(Key={'deviceId': device_id})
        if 'Item' in res and 'music_tracks' in res['Item']:
            # DB에 "1_6_11_16" 형태로 저장된 문자열을 자름
            track_list = str(res['Item']['music_tracks']).split('_')
            if 1 <= spray_code <= 4 and len(track_list) == 4:
                return int(track_list[spray_code - 1])
    except Exception as e:
        logger.error(f"Music Load Error: {e}")
        
    # 데이터가 없거나 에러나면 기본값 반환
    defaults = {1: 1, 2: 6, 3: 11, 4: 16}
    return defaults.get(int(spray_code), int(spray_code))

def save_feedback(email, context, scent_code, weight_change): # 파라미터를 email로 변경
    try:
        score_col = f"scent_{scent_code}_score"
        
        pref_table.update_item(
            Key={
                'email': str(email), # 이제 기기가 아니라 이메일 단위로 저장!
                'context': str(context)
            },
            UpdateExpression=f"ADD {score_col} :val",
            ExpressionAttributeValues={':val': int(weight_change)}
        )
        return True
    except Exception as e:
        logger.error(f"Feedback Save Error: {e}")
        return False

def get_personalized_scent(email, context, default_scent):
    try:
        # 여기도 키 이름을 (String) 포함된 걸로 변경
        resp = pref_table.get_item(Key={
            'email': str(email), 
            'context': str(context)
        })
        item = resp.get('Item')
        
        if not item: return default_scent, "기본 추천"

        scores = {
            1: int(item.get('scent_1_score', 0)),
            2: int(item.get('scent_2_score', 0)),
            3: int(item.get('scent_3_score', 0)),
            4: int(item.get('scent_4_score', 0))
        }

        max_score = max(scores.values())
        if max_score > 0:
            best_scents = [scent for scent, score in scores.items() if score == max_score]
            if int(default_scent) in best_scents:
                return default_scent, "가중치 확인(유지)"
            else:
                new_scent = random.choice(best_scents)
                return new_scent, "사용자 선호 가중치 적용"

        return default_scent, "기본 추천"
    except Exception as e:
        logger.error(f"Personalization Error: {e}")
        return default_scent, "에러(기본값)"

# ★ 이 부분이 0.1초만에 기기를 꺼버리던 주범이었습니다! 완전히 -1로 수정 완료
def manage_mailbox(device_id, save_cmd=None, save_region=None, save_duration=None):
    try:
        if save_cmd is not None:
            update_exp = "set pending_cmd = :c"
            exp_vals = {':c': int(save_cmd)}
            if save_region:
                update_exp += ", pending_region = :r"
                exp_vals[':r'] = str(save_region)
            # 분사 시간 저장 (없으면 무시)
            if save_duration is not None:
                update_exp += ", pending_duration = :d"
                exp_vals[':d'] = int(save_duration)

            state_table.update_item(
                Key={'deviceId': device_id},
                UpdateExpression=update_exp,
                ExpressionAttributeValues=exp_vals
            )
            return int(save_cmd)
        else:
            res = state_table.get_item(Key={'deviceId': device_id})
            if 'Item' in res:
                # ★ 변경됨: 대기열 기본값을 0이 아니라 -1로 읽음
                cmd = int(res['Item'].get('pending_cmd', -1))
                saved_region = res['Item'].get('pending_region', "") 
                saved_duration = int(res['Item'].get('pending_duration', 3))

                # ★ 변경됨: cmd가 -1(명령 없음)이 아닐 때만 실행
                if cmd != -1:
                    state_table.update_item(
                        Key={'deviceId': device_id},
                        # ★ 변경됨: 초기화 시 0(정지명령)이 아닌 -1(명령없음)로 덮어씀
                        UpdateExpression="set pending_cmd = :z, pending_region = :e, pending_duration = :d",
                        ExpressionAttributeValues={':z': -1, ':e': "", ':d': 3}
                    )
                    return cmd, saved_region, saved_duration 
            # ★ 변경됨: 반환값도 -1
            return -1, "", 3 
    except Exception as e:
        logger.error(f"Mailbox Error: {e}")
        # ★ 변경됨: 에러 시 반환값도 -1
        return -1, "", 3

def get_device_state(device_id):
    try:
        res = state_table.get_item(Key={'deviceId': device_id})
        if 'Item' in res: return res['Item']
        return {
            'deviceId': device_id,
            'last_spray_time': "2000-01-01T00:00:00",
            'current_capacity': Decimal(str(config.MAX_CAPACITY)),
            'last_spray_code': 0,
            'weight_g': Decimal("0"),
            'weights': [Decimal("0"), Decimal("0"), Decimal("0"), Decimal("0")]
        }
    except: return None

def _normalize_weight_list(weights_value):
    normalized = []

    if isinstance(weights_value, list):
        source_values = weights_value[:4]
    else:
        source_values = [weights_value]

    for value in source_values:
        try:
            normalized.append(float(value))
        except Exception:
            normalized.append(0.0)

    while len(normalized) < 4:
        normalized.append(0.0)

    return normalized[:4]


def update_device_state(device_id, last_time, new_capacity, spray_code, weights_value):
    try:
        normalized_weights = _normalize_weight_list(weights_value)
        state_table.update_item(
            Key={'deviceId': device_id},
            UpdateExpression="set last_spray_time = :t, current_capacity = :c, last_spray_code = :s, weight_g = :wg, weights = :w",
            ExpressionAttributeValues={
                ':t': last_time,
                ':c': Decimal(str(new_capacity)),
                ':s': int(spray_code),
                ':wg': Decimal(str(normalized_weights[0])),
                ':w': [Decimal(str(weight)) for weight in normalized_weights]
            }
        )
    except Exception as e:
        logger.error(f"DB Write Error: {e}")

def get_user_preference_summary(device_id):
    """
    특정 기기(사용자)의 과거 좋아요/싫어요 데이터를 분석해
    AI에게 전달할 프롬프트용 텍스트를 생성합니다.
    """
    try:
        # 감성 모드(Emotion_Analysis)에서의 누적 피드백 점수 가져오기
        resp = pref_table.get_item(Key={
            'deviceId': str(device_id), 
            'context': "Emotion_Analysis"
        })
        item = resp.get('Item', {})
        
        scores = {
            "시트러스(1)": int(item.get('scent_1_score', 0)),
            "라벤더(2)": int(item.get('scent_2_score', 0)),
            "우디(3)": int(item.get('scent_3_score', 0)),
            "쿨민트(4)": int(item.get('scent_4_score', 0)),
            "플로럴(5)": int(item.get('scent_5_score', 0)),
            "머스크(6)": int(item.get('scent_6_score', 0))
        }
        
        # AI가 이해하기 쉽게 점수를 문장으로 변환
        summary_text = ""
        for scent_name, score in scores.items():
            if score > 0:
                summary_text += f"- {scent_name}: 과거에 좋아함 (가중치 +{score})\n"
            elif score < 0:
                summary_text += f"- {scent_name}: 과거에 싫어함 (가중치 {score})\n"
                
        if not summary_text:
            return "아직 누적된 향기 선호도 데이터가 없습니다."
            
        return summary_text
        
    except Exception as e:
        logger.error(f"Preference Summary Error: {e}")
        return "사용자 취향 데이터를 불러오지 못했습니다."

