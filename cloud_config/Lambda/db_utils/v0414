        # 1~6번 향기 점수 취합
        scores = {i: int(item.get(f'scent_{i}_score', 0)) for i in range(1, 7)}
        scent_names = {1: "시트러스", 2: "라벤더", 3: "우디", 4: "쿨민트", 5: "플로럴", 6: "머스크"}
        
        summary = ""
        for i, score in scores.items():
            if score > 0: summary += f"- {scent_names[i]}: 선호 (+{score})\n"
            elif score < 0: summary += f"- {scent_names[i]}: 비선호 ({score})\n"
            
        return summary if summary else "아직 누적된 취향 데이터가 없습니다."
    except Exception as e:
        logger.error(f"Summary Error: {e}")
        return "데이터 불러오기 오류"

