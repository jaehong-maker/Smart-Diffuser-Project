def get_ai_recommendation(weather_text, humidity_val):
    try:
        # 지훈이의 AI 람다 API 엔드포인트 주소
        ai_url = "https://vmqkp1y6f4.execute-api.ap-northeast-2.amazonaws.com/default/Diffuser-AI-Final"
        
        weather_map = {"맑음": 1, "흐림": 2, "비": 3, "눈": 4}
        weather_code = 1
        for key, value in weather_map.items():
            if key in weather_text:
                weather_code = value
                break

        payload = json.dumps({
            "weather": weather_code, 
            "humidity": float(humidity_val)
        }).encode('utf-8')

        req = urllib.request.Request(ai_url, data=payload, method='POST')
        req.add_header('Content-Type', 'application/json')
        
        with urllib.request.urlopen(req, timeout=5) as res:
            result = json.loads(res.read().decode('utf-8'))
            return result.get("spray", 1) 
    except Exception as e:
        print(f"AI 서버 연동 실패: {e}")
        return None
