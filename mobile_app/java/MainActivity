package com.example.diffuser3; // ★ 패키지명 확인!

import android.Manifest;
import android.content.pm.PackageManager;
import android.location.Address;
import android.location.Geocoder;
import android.os.Bundle;
import android.view.View;
import android.widget.LinearLayout;
import android.widget.TextView;
import android.widget.Toast;

import androidx.appcompat.app.AppCompatActivity;
import androidx.core.app.ActivityCompat;

import com.google.android.gms.location.FusedLocationProviderClient;
import com.google.android.gms.location.LocationServices;

import java.io.IOException;
import java.util.List;
import java.util.Locale;

public class MainActivity extends AppCompatActivity {

    // 레이아웃
    LinearLayout layoutMenu, layoutManual, layoutEmotion, layoutWeather, layoutSetting;
    LinearLayout layoutFeedback; // 피드백 화면

    // 텍스트뷰
    TextView txtStatus, txtRegion, txtWeatherInfo;
    TextView txtCurrentScent;     // 날씨 모드용 향기 표시
    TextView txtCurrentScentEmo;  // 감성 모드용 향기 표시

    // 위치 및 상태 변수
    private FusedLocationProviderClient fusedLocationClient;
    private String currentRegion = "서울";

    // 피드백 및 로직용 변수
    private int lastScent = 0;
    private String lastContext = "Manual"; // Manual, Weather_지역, Emotion_감정

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        // 1. UI 연결
        layoutMenu = findViewById(R.id.layoutMenu);
        layoutManual = findViewById(R.id.layoutManual);
        layoutEmotion = findViewById(R.id.layoutEmotion);
        layoutWeather = findViewById(R.id.layoutWeather);
        layoutSetting = findViewById(R.id.layoutSetting);
        layoutFeedback = findViewById(R.id.layoutFeedback);

        txtStatus = findViewById(R.id.txtStatus);
        txtRegion = findViewById(R.id.txtRegion);
        txtWeatherInfo = findViewById(R.id.txtWeatherInfo);

        // ★ 향기 표시 텍스트뷰 연결
        txtCurrentScent = findViewById(R.id.txtCurrentScent);
        txtCurrentScentEmo = findViewById(R.id.txtCurrentScentEmo);

        fusedLocationClient = LocationServices.getFusedLocationProviderClient(this);

        // ==========================================
        // ★ [피드백] 좋아요/싫어요 버튼
        // ==========================================
        findViewById(R.id.btnLike).setOnClickListener(v -> sendFeedback("good"));
        findViewById(R.id.btnDislike).setOnClickListener(v -> sendFeedback("bad"));

        // ==========================================
        // ★ [공통] 뒤로가기 (메뉴 복귀)
        // ==========================================
        View.OnClickListener backToMenuListener = v -> {
            // ESP32에게 메뉴 복귀 명령(90) 전송
            sendCommand(Constants.ACTION_MANUAL, 90, currentRegion);
            showLayout("MENU");
        };

        // ==========================================
        // [1] 메인 메뉴 버튼 (모드 진입)
        // ==========================================
        findViewById(R.id.btnModeManual).setOnClickListener(v -> {
            lastContext = "Manual";
            sendCommand(Constants.ACTION_MANUAL, 10, currentRegion);
            showLayout("MANUAL");
        });

        findViewById(R.id.btnModeEmotion).setOnClickListener(v -> {
            lastContext = "Emotion";
            sendCommand(Constants.ACTION_MANUAL, 20, currentRegion);
            showLayout("EMOTION");
        });

        findViewById(R.id.btnModeWeather).setOnClickListener(v -> {
            lastContext = "Weather";
            sendCommand(Constants.ACTION_MANUAL, 30, currentRegion);
            showLayout("WEATHER");
        });

        findViewById(R.id.btnModeSetting).setOnClickListener(v -> showLayout("SETTING"));

        // 데모 & 음성 모드 안내
        findViewById(R.id.btnModeDemo).setOnClickListener(v -> Toast.makeText(this, "ESP32에서 [5]번을 눌러주세요", Toast.LENGTH_SHORT).show());
        findViewById(R.id.btnModeVoice).setOnClickListener(v -> Toast.makeText(this, "ESP32에서 [6]번을 눌러주세요", Toast.LENGTH_SHORT).show());

        // ==========================================
        // [2] 수동 제어
        // ==========================================
        findViewById(R.id.btnScent1).setOnClickListener(v -> sendCommand(Constants.ACTION_MANUAL, 1, currentRegion));
        findViewById(R.id.btnScent2).setOnClickListener(v -> sendCommand(Constants.ACTION_MANUAL, 2, currentRegion));
        findViewById(R.id.btnScent3).setOnClickListener(v -> sendCommand(Constants.ACTION_MANUAL, 3, currentRegion));
        findViewById(R.id.btnScent4).setOnClickListener(v -> sendCommand(Constants.ACTION_MANUAL, 4, currentRegion));

        findViewById(R.id.btnBackFromManual).setOnClickListener(backToMenuListener);

        // ==========================================
        // [3] 감성 모드 (AI_EMOTION 사용)
        // ==========================================
        findViewById(R.id.btnEmoHappy).setOnClickListener(v -> sendEmotionCommand("Happy"));
        findViewById(R.id.btnEmoRelax).setOnClickListener(v -> sendEmotionCommand("Relax"));
        findViewById(R.id.btnEmoAngry).setOnClickListener(v -> sendEmotionCommand("Angry"));
        findViewById(R.id.btnEmoSad).setOnClickListener(v -> sendEmotionCommand("Sad"));

        findViewById(R.id.btnBackFromEmotion).setOnClickListener(backToMenuListener);

        // ==========================================
        // [4] 설정 모드
        // ==========================================
        findViewById(R.id.btnSetTare).setOnClickListener(v -> sendCommand(Constants.ACTION_MANUAL, 91, currentRegion));
        findViewById(R.id.btnSetSave).setOnClickListener(v -> sendCommand(Constants.ACTION_MANUAL, 92, currentRegion));
        findViewById(R.id.btnSetPlus).setOnClickListener(v -> sendCommand(Constants.ACTION_MANUAL, 93, currentRegion));
        findViewById(R.id.btnSetMinus).setOnClickListener(v -> sendCommand(Constants.ACTION_MANUAL, 94, currentRegion));

        findViewById(R.id.btnBackFromSetting).setOnClickListener(backToMenuListener);

        // ==========================================
        // [5] 날씨 모드 (AI_WEATHER 사용)
        // ==========================================
        findViewById(R.id.btnGps).setOnClickListener(v -> getCurrentLocation());

        findViewById(R.id.btnBackFromWeather).setOnClickListener(backToMenuListener);

        requestPermission();
    }

    // =============================================================
    // ★ [핵심 1] 통합 전송 함수 (화면 업데이트 포함)
    // =============================================================
    private void sendCommand(String action, int valueSent, String data) {
        txtStatus.setText("상태: 📡 AI 분석 요청 중...");

        NetworkHelper.sendData(action, valueSent, data, new NetworkHelper.NetworkCallback() {
            @Override
            public void onSuccess(int realSpray, String message) {
                // 상단 상태바 업데이트
                txtStatus.setText("상태: ✅ " + message);

                // ★ 중앙 날씨 정보 업데이트 (피드백 완료 메시지로 덮어쓰기 방지)
                // 'AI_WEATHER' 요청이거나, 현재 컨텍스트가 날씨일 때만 날씨 정보를 업데이트
                if (action.equals("AI_WEATHER")) {
                    txtWeatherInfo.setText("현재 날씨: " + message);
                }

                // 분사 성공(1~4번) 했고, 메뉴 복귀(90) 명령이 아닐 때
                if(realSpray >= 1 && realSpray <= 4) {
                    lastScent = realSpray;

                    // ★ 향기 텍스트 업데이트 (날씨/감성 둘 다)
                    String scentName = getScentName(realSpray);
                    txtCurrentScent.setText("💨 분사 중: " + scentName);
                    txtCurrentScentEmo.setText("💨 분사 중: " + scentName);

                    // 수동 모드가 아닐 때만 피드백 버튼 표시
                    if (!lastContext.equals("Manual")) {
                        layoutFeedback.setVisibility(View.VISIBLE);
                    } else {
                        layoutFeedback.setVisibility(View.GONE);
                    }
                }
                else if(valueSent == 90) {
                    Toast.makeText(MainActivity.this, "메뉴로 복귀합니다", Toast.LENGTH_SHORT).show();
                    layoutFeedback.setVisibility(View.GONE);
                    // 텍스트 초기화
                    txtCurrentScent.setText("향기 대기 중...");
                    txtCurrentScentEmo.setText("감정을 선택해주세요");
                }
            }
            @Override
            public void onFailure(String errorMsg) {
                txtStatus.setText("상태: 🚨 실패");
                Toast.makeText(MainActivity.this, errorMsg, Toast.LENGTH_SHORT).show();
            }
        });
    }

    // =============================================================
    // ★ [핵심 2] 피드백 전송 (lastContext 전송)
    // =============================================================
// =============================================================
    // ★ [핵심 2] 피드백 전송 (lastContext 전송) 및 대체 향기 적용
    // =============================================================
    private void sendFeedback(String rating) {
        int ratingVal = rating.equals("good") ? 1 : 0;
        txtStatus.setText("상태: 피드백 반영 중...");

        // 1. 서버로 피드백 데이터 전송 (기존 로직 유지)
        sendCommand(Constants.ACTION_FEEDBACK, ratingVal, lastContext);

        // 2. ★ [추가된 핵심 로직] '싫어요'를 눌렀을 때 즉각 향기 교체
        if (rating.equals("bad")) {
            // 현재 향기(lastScent)가 무엇인지 확인하고, 다른 향기 번호(1~4 순환)로 바꿈
            // 예: 1번이면 2번으로, 4번이면 1번으로
            int nextScent = (lastScent % 4) + 1;

            // 기기에 새로운 향기를 즉시 분사하라고 수동(ACTION_MANUAL) 명령 전송
            sendCommand(Constants.ACTION_MANUAL, nextScent, currentRegion);

            Toast.makeText(this, "취향에 맞게 다른 향기로 바꿉니다 🔄", Toast.LENGTH_SHORT).show();
        } else {
            Toast.makeText(this, "피드백이 반영되었습니다 😊", Toast.LENGTH_SHORT).show();
        }

        layoutFeedback.setVisibility(View.GONE); // 전송 후 버튼 숨김
    }
    // =============================================================
    // ★ [핵심 3] 감성 AI 요청
    // =============================================================
    private void sendEmotionCommand(String emotion) {
        lastContext = "Emotion_" + emotion; // 컨텍스트 저장
        txtStatus.setText("상태: 감성(" + emotion + ") 분석 요청...");

        // 숫자는 0, data 자리에 감정 텍스트를 보냄
        sendCommand("AI_EMOTION", 0, emotion);
    }

    // =============================================================
    // ★ [핵심 4] 날씨 AI 요청
    // =============================================================
    private void getCurrentLocation() {
        if (ActivityCompat.checkSelfPermission(this, Manifest.permission.ACCESS_FINE_LOCATION) != PackageManager.PERMISSION_GRANTED) {
            requestPermission();
            return;
        }
        txtRegion.setText("위치 찾는 중...");
        txtWeatherInfo.setText("날씨 조회 중..."); // 로딩 표시

        fusedLocationClient.getLastLocation().addOnSuccessListener(this, location -> {
            if (location != null) {
                currentRegion = getRegionName(location.getLatitude(), location.getLongitude());
                txtRegion.setText("현재 위치: " + currentRegion);

                lastContext = "Weather_" + currentRegion; // 컨텍스트 저장

                // 날씨 AI 요청
                sendCommand("AI_WEATHER", 0, currentRegion);
            } else {
                txtRegion.setText("위치 실패 (GPS 확인)");
                txtWeatherInfo.setText("위치 정보 없음");
            }
        });
    }

    // 화면 전환 함수
    private void showLayout(String type) {
        layoutMenu.setVisibility(View.GONE);
        layoutManual.setVisibility(View.GONE);
        layoutEmotion.setVisibility(View.GONE);
        layoutWeather.setVisibility(View.GONE);
        layoutSetting.setVisibility(View.GONE);
        layoutFeedback.setVisibility(View.GONE); // 화면 전환 시 피드백 숨김

        // 기본적으로 상태창 보이기
        txtStatus.setVisibility(View.VISIBLE);

        if (type.equals("MENU")) {
            layoutMenu.setVisibility(View.VISIBLE);
            txtStatus.setText("상태: 메뉴 선택 중...");
        } else if (type.equals("MANUAL")) {
            layoutManual.setVisibility(View.VISIBLE);
            txtStatus.setText("상태: 🎮 수동 제어 모드");
        } else if (type.equals("EMOTION")) {
            layoutEmotion.setVisibility(View.VISIBLE);
            // ★ 감성 모드에서는 상태창 숨기기
            txtStatus.setVisibility(View.GONE);
            txtCurrentScentEmo.setText("감정을 선택해주세요"); // 초기화
        } else if (type.equals("WEATHER")) {
            layoutWeather.setVisibility(View.VISIBLE);
            txtStatus.setText("상태: 🌦️ 날씨 모드");
        } else if (type.equals("SETTING")) {
            layoutSetting.setVisibility(View.VISIBLE);
            txtStatus.setText("상태: 🛠️ 설정 모드");
        }
    }

    // 향기 번호를 이름으로 변환하는 헬퍼 함수
    private String getScentName(int sprayCode) {
        switch (sprayCode) {
            case 1: return "🍊 시트러스";
            case 2: return "🌿 라벤더";
            case 3: return "🌊 아쿠아";
            case 4: return "❄️ 민트";
            default: return "❓ 대기 중";
        }
    }

    // 위치 관련 헬퍼 함수들
    private String getRegionName(double lat, double lng) {
        Geocoder geocoder = new Geocoder(this, Locale.KOREA);
        try {
            List<Address> addresses = geocoder.getFromLocation(lat, lng, 1);
            if (addresses != null && !addresses.isEmpty()) {
                return mapToLambdaRegion(addresses.get(0).getAddressLine(0));
            }
        } catch (IOException e) { e.printStackTrace(); }
        return "서울";
    }

    private String mapToLambdaRegion(String fullAddress) {
        if (fullAddress == null) return "서울";
        if (fullAddress.contains("안양")) return "안양";
        if (fullAddress.contains("수원")) return "수원";
        if (fullAddress.contains("성남") || fullAddress.contains("분당")) return "성남";
        if (fullAddress.contains("용인") || fullAddress.contains("수지")) return "용인";
        if (fullAddress.contains("고양") || fullAddress.contains("일산")) return "고양";
        if (fullAddress.contains("부천")) return "부천";
        if (fullAddress.contains("서울")) return "서울";
        if (fullAddress.contains("경기")) return "경기";
        if (fullAddress.contains("인천")) return "인천";
        return "서울";
    }

    private void requestPermission() {
        if (ActivityCompat.checkSelfPermission(this, Manifest.permission.ACCESS_FINE_LOCATION) != PackageManager.PERMISSION_GRANTED) {
            ActivityCompat.requestPermissions(this, new String[]{Manifest.permission.ACCESS_FINE_LOCATION}, 100);
        }
    }
}
